<Window x:Class="RenPyTRLauncher.Views.ImageViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Görüntü Görüntüleme" Height="600" Width="800"
        Background="#000000" WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize" WindowStyle="SingleBorderWindow">
    
    <Grid>
        <Image x:Name="ImgViewer" Stretch="Uniform"/>
        <Button x:Name="BtnClose" Content="✕" Width="40" Height="40" 
                HorizontalAlignment="Right" VerticalAlignment="Top" 
                Margin="16" Background="#33FFFFFF" Foreground="White" 
                BorderThickness="0" FontSize="20" Cursor="Hand" Click="BtnClose_Click"/>
    </Grid>
</Window>
