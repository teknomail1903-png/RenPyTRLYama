<Window x:Class="RenPyTRLauncher.Views.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Şifre Değiştir" Height="380" Width="420"
        WindowStartupLocation="CenterOwner" Background="#0D0D0F">

    <Window.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#9B59FF"/>
        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="#222228"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style x:Key="SaveBtn" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#1A1A22" CornerRadius="12" Margin="20" Padding="24">
        <StackPanel>
            <TextBlock Text="🔐 Şifre Değiştir" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,16"/>
            <TextBlock Text="Mevcut Şifre" Foreground="#AAA" FontSize="12"/>
            <PasswordBox x:Name="TxtCurrent"/>
            <TextBlock Text="Yeni Şifre" Foreground="#AAA" FontSize="12"/>
            <PasswordBox x:Name="TxtNew"/>
            <TextBlock Text="Yeni Şifre Tekrar" Foreground="#AAA" FontSize="12"/>
            <PasswordBox x:Name="TxtNew2"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                <Button Content="İptal" Width="90" Margin="0,0,8,0" Click="BtnCancel_Click"/>
                <Button Content="Kaydet" Style="{StaticResource SaveBtn}" Width="100" Click="BtnSave_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
