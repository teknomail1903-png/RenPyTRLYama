<Window x:Class="RenPyTRLauncher.Views.EditProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:RenPyTRLauncher.Data"
        Title="Profili Düzenle" Height="520" Width="480"
        Background="#0D0D0F" WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <local:AvatarImageConverter x:Key="AvatarImage"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#66C0F4"/>
        <SolidColorBrush x:Key="CardBrush" Color="#1A1A22"/>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#AAA"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#222228"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource CardBrush}" CornerRadius="12" Margin="16" Padding="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="👤 Profil Düzenle" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,16"/>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Grid Width="72" Height="72">
                            <Ellipse Fill="{Binding AvatarPath, Converter={StaticResource AvatarImage}}" Stroke="#66C0F4" StrokeThickness="2"/>
                            <Image x:Name="ImgAvatar" Stretch="UniformToFill">
                                <Image.Clip>
                                    <EllipseGeometry Center="36,36" RadiusX="36" RadiusY="36"/>
                                </Image.Clip>
                            </Image>
                        </Grid>
                        <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                            <Button x:Name="BtnUploadAvatar" Content="📷 Fotoğraf Yükle" Padding="12,6" Margin="0,0,0,6"/>
                            <TextBlock Text="Varsayılan Avatar" Foreground="#888" FontSize="11" Margin="0,0,0,4"/>
                            <WrapPanel x:Name="AvatarPicker" Width="280"/>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Text="Kullanıcı Adı"/>
                    <TextBox x:Name="TxtUsername" IsReadOnly="True" Opacity="0.7"/>
                    <TextBlock Text="E-posta"/>
                    <TextBox x:Name="TxtEmail"/>
                    <TextBlock Text="Şehir"/>
                    <TextBox x:Name="TxtCity"/>
                    <TextBlock Text="Yaş"/>
                    <TextBox x:Name="TxtAge"/>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button x:Name="BtnCancel" Content="İptal" Width="90" Margin="0,0,8,0" Padding="8"/>
                <Button x:Name="BtnSave" Content="Kaydet" Width="100" Padding="8"
                        Background="{StaticResource AccentBrush}" Foreground="White" BorderThickness="0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
