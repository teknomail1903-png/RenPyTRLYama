<Window x:Class="RenPyTRLauncher.Views.EditUserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kullanıcı Düzenle" Height="480" Width="460"
        WindowStartupLocation="CenterOwner" Background="#0D0D0F">

    <Window.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#9B59FF"/>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#222228"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style x:Key="SaveBtn" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#1A1A22" CornerRadius="12" Margin="16" Padding="20">
        <StackPanel>
            <TextBlock Text="👤 Kullanıcı Bilgileri" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,14"/>
            <TextBlock Text="Kullanıcı Adı" Foreground="#AAA" FontSize="12"/>
            <TextBox x:Name="TxtUsername"/>
            <TextBlock Text="E-posta" Foreground="#AAA" FontSize="12"/>
            <TextBox x:Name="TxtEmail"/>
            <TextBlock Text="Rol" Foreground="#AAA" FontSize="12"/>
            <ComboBox x:Name="CmbRole" Margin="0,0,0,10" Background="#222228" Foreground="White" FontWeight="SemiBold"/>
            <TextBlock Text="Üyelik Seviyesi" Foreground="#AAA" FontSize="12"/>
            <ComboBox x:Name="CmbMembership" Margin="0,0,0,10" Background="#222228" Foreground="White" FontWeight="SemiBold"/>
            <TextBlock Text="Profil Resmi (URL veya yükle)" Foreground="#AAA" FontSize="12"/>
            <StackPanel Orientation="Horizontal">
                <TextBox x:Name="TxtAvatar" Width="300"/>
                <Button x:Name="BtnBrowseAvatar" Content="Yükle" Margin="8,0,0,10" Padding="10,6" Click="BtnBrowseAvatar_Click"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                <Button Content="İptal" Width="90" Margin="0,0,8,0" Click="BtnCancel_Click"/>
                <Button Content="Kaydet" Style="{StaticResource SaveBtn}" Width="100" Click="BtnSave_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
