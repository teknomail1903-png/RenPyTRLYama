<Window x:Class="RenPyTRLauncher.Views.EditGameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Oyun Düzenle" Height="360" Width="500">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="İsim" />
        <TextBox x:Name="TxtName" Grid.Row="1" Margin="0,4,0,8" />

        <TextBlock Text="Açıklama" Grid.Row="2" />
        <TextBox x:Name="TxtDesc" Grid.Row="3" Margin="0,4,0,8" />

        <StackPanel Grid.Row="4" Orientation="Vertical">
            <TextBlock Text="Versiyon" />
            <TextBox x:Name="TxtVersion" Margin="0,4,0,8" />
            <TextBlock Text="Yama Versiyonu" />
            <TextBox x:Name="TxtPatchVersion" Margin="0,4,0,8" />
            <TextBlock Text="Kategoriler (noktalı virgülle ayırın)" />
            <TextBox x:Name="TxtCategories" Margin="0,4,0,8" />
            <TextBlock Text="Image Path" />
            <StackPanel Orientation="Horizontal">
                <TextBox x:Name="TxtImage" Margin="0,4,0,8" Width="300"/>
                <Button x:Name="BtnBrowseImage" Content="Gözat" Margin="8,4,0,8" Width="80"/>
            </StackPanel>
            <TextBlock Text="Patch Path / URL" />
            <TextBlock Text="https://... veya github:owner/repo/SummerMemories_TR_v1.0.zip" Foreground="Gray" FontSize="11"/>
            <StackPanel Orientation="Horizontal">
                <TextBox x:Name="TxtPatch" Margin="0,4,0,8" Width="300"/>
                <Button x:Name="BtnBrowsePatch" Content="Yama Seç" Margin="8,4,0,8" Width="80"/>
            </StackPanel>
            <TextBlock Text="Etiketler / Durum" />
            <StackPanel Orientation="Horizontal" Margin="0,4,0,8">
                <CheckBox x:Name="ChkIsVip" Content="VIP" Margin="0,0,8,0"/>
                <CheckBox x:Name="ChkIsTop10" Content="Top10" Margin="0,0,8,0"/>
                <CheckBox x:Name="ChkIsFeatured" Content="Öne Çıkan" />
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnCancel" Content="İptal" Width="80" Margin="0,6,8,0" />
            <Button x:Name="BtnSave" Content="Kaydet" Width="100" Margin="0,6,0,0" />
        </StackPanel>
    </Grid>
</Window>
