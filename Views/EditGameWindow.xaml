<Window x:Class="RenPyTRLauncher.Views.EditGameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Oyun Düzenle" Height="700" Width="600"
        Background="#0D0D0F" WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <SolidColorBrush x:Key="CardBrush" Color="#1A1A22"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#9B59FF"/>
        <SolidColorBrush x:Key="SectionHeaderBrush" Color="#3498DB"/>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#AAA"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#222228"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="0,0,16,0"/>
        </Style>
        <Style x:Key="SaveBtn" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource SectionHeaderBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource CardBrush}" CornerRadius="12" Margin="16" Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="🎮 Oyun Bilgileri" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,16"/>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Üst Bölüm: Görsel ve Temel Bilgiler -->
                    <Border Background="#252530" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="📸 Görsel ve Temel Bilgiler" Style="{StaticResource SectionHeader}" Foreground="White"/>
                            <TextBlock Text="Oyun Adı"/>
                            <TextBox x:Name="TxtName"/>
                            
                            <TextBlock Text="Kapak Resmi"/>
                            <Border Background="#1A1A22" CornerRadius="6" Padding="12" Margin="0,0,0,10">
                                <StackPanel>
                                    <Border x:Name="ImgCoverPreview" Background="#0D0D0F" Height="120" CornerRadius="4" Margin="0,0,0,8">
                                        <TextBlock Text="Kapak resmi önizleme" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#555"/>
                                    </Border>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBox x:Name="TxtImage" Width="280"/>
                                        <Button x:Name="BtnBrowseImage" Content="Yükle" Margin="8,0,0,0" Padding="12,6"/>
                                        <Button x:Name="BtnUrlImage" Content="URL" Margin="8,0,0,0" Padding="12,6"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            
                            <TextBlock Text="Ekran Görüntüleri"/>
                            <Border Background="#1A1A22" CornerRadius="6" Padding="12" Margin="0,0,0,10">
                                <StackPanel>
                                    <Border x:Name="ImgScreenshotsPreview" Background="#0D0D0F" Height="80" CornerRadius="4" Margin="0,0,0,8">
                                        <TextBlock Text="Ekran görüntüleri önizleme" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#555"/>
                                    </Border>
                                    <TextBox x:Name="TxtScreenshots" Height="50" AcceptsReturn="True" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                    <Button x:Name="BtnAddScreenshot" Content="Görsel Ekle" Padding="12,6" HorizontalAlignment="Left"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Orta Bölüm: Açıklama ve Kategoriler -->
                    <Border Background="#252530" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="📝 Açıklama ve Kategoriler" Style="{StaticResource SectionHeader}" Foreground="White"/>
                            <TextBlock Text="Kısa Açıklama"/>
                            <TextBox x:Name="TxtDesc" Height="60" AcceptsReturn="True" TextWrapping="Wrap"/>
                            
                            <TextBlock Text="Versiyon"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBox x:Name="TxtVersion" Width="150"/>
                                <TextBlock Text="Mod Versiyonu" Margin="20,0,0,0"/>
                                <TextBox x:Name="TxtPatchVersion" Width="150"/>
                            </StackPanel>

                            <TextBlock Text="Tür"/>
                            <ComboBox x:Name="CmbGameType" Background="#222228" Foreground="White" BorderBrush="#333" Padding="8,6" Margin="0,0,0,10">
                                <ComboBoxItem Content="Oyun" Tag="Game"/>
                                <ComboBoxItem Content="Türkçe Mod" Tag="Translation"/>
                                <ComboBoxItem Content="Galeri Modu" Tag="Gallery"/>
                                <ComboBoxItem Content="Cheat Mod" Tag="Cheat"/>
                                <ComboBoxItem Content="Walkthrough" Tag="Walkthrough"/>
                                <ComboBoxItem Content="Save Dosyası" Tag="Save"/>
                                <ComboBoxItem Content="Ek İçerik" Tag="Extra"/>
                            </ComboBox>

                            <TextBlock Text="Kategoriler"/>
                            <ListBox x:Name="LstCategories" SelectionMode="Multiple" Height="80" Background="#222228"
                                     Foreground="White" BorderBrush="#333" Margin="0,0,0,10"/>

                            <TextBlock Text="Etiketler (Steam Tarzı)"/>
                            <Border Background="#1A1A22" CornerRadius="6" Padding="12" Margin="0,0,0,10">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBox x:Name="TxtNewTag" Width="200"/>
                                        <Button x:Name="BtnAddTag" Content="Ekle" Margin="8,0,0,0" Padding="12,6"/>
                                    </StackPanel>
                                    <ItemsControl x:Name="TagList">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#2A2A35" CornerRadius="16" Padding="12,6" Margin="0,0,8,8">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding}" Foreground="White" FontSize="13"/>
                                                        <Button Content="×" Background="Transparent" Foreground="#E74C3C" BorderThickness="0" 
                                                                FontSize="16" Padding="4,0,0,0" Margin="8,0,0,0" Cursor="Hand"
                                                                Click="RemoveTag_Click" Tag="{Binding}"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <TextBlock x:Name="LblGameSelection" Text="Bağlı Oyun Seç (Modlar için)" Visibility="Collapsed"/>
                            <ComboBox x:Name="CmbGameSelection" Visibility="Collapsed" Background="#222228" Foreground="White" BorderBrush="#333" Padding="8,6" Margin="0,0,0,10"/>
                            <TextBlock x:Name="LblNoGameWarning" Text="⚠️ Önce bir oyun eklemelisiniz." Foreground="#E74C3C" Visibility="Collapsed" Margin="0,0,0,10"/>
                        </StackPanel>
                    </Border>

                    <!-- Yeni Bölüm: Detaylı Oyun Bilgileri -->
                    <Border Background="#252530" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="🎯 Detaylı Oyun Bilgileri" Style="{StaticResource SectionHeader}" Foreground="White"/>
                            
                            <TextBlock Text="Türkçe Durumu"/>
                            <ComboBox x:Name="CmbTurkishStatus" Background="#222228" Foreground="White" BorderBrush="#333" Padding="8,6" Margin="0,0,0,10">
                                <ComboBoxItem Content="Evet" Tag="Evet"/>
                                <ComboBoxItem Content="Hayır" Tag="Hayır"/>
                                <ComboBoxItem Content="Devam Ediyor" Tag="DevamEdiyor"/>
                                <ComboBoxItem Content="Kısmi Çeviri" Tag="KismiCeviri"/>
                            </ComboBox>

                            <TextBlock Text="Steam Durumu"/>
                            <ComboBox x:Name="CmbSteamStatus" Background="#222228" Foreground="White" BorderBrush="#333" Padding="8,6" Margin="0,0,0,10">
                                <ComboBoxItem Content="Var" Tag="Var"/>
                                <ComboBoxItem Content="Yok" Tag="Yok"/>
                            </ComboBox>

                            <TextBlock Text="Tamamlanma Durumu"/>
                            <ComboBox x:Name="CmbCompletionStatus" Background="#222228" Foreground="White" BorderBrush="#333" Padding="8,6" Margin="0,0,0,10">
                                <ComboBoxItem Content="Tamamlandı" Tag="Tamamlandi"/>
                                <ComboBoxItem Content="Devam Ediyor" Tag="DevamEdiyor"/>
                                <ComboBoxItem Content="Beklemede" Tag="Beklemede"/>
                            </ComboBox>

                            <TextBlock Text="Geliştirici"/>
                            <TextBox x:Name="TxtDeveloper" Margin="0,0,0,10"/>

                            <TextBlock Text="Yayıncı"/>
                            <TextBox x:Name="TxtPublisher" Margin="0,0,0,10"/>

                            <TextBlock Text="Oyun Motoru"/>
                            <TextBox x:Name="TxtGameEngine" Margin="0,0,0,10"/>

                            <TextBlock Text="Çıkış Tarihi"/>
                            <DatePicker x:Name="DtpReleaseDate" Background="#222228" Foreground="White" BorderBrush="#333" Padding="8,6" Margin="0,0,0,10"/>

                            <TextBlock Text="Ortalama Oyun Süresi"/>
                            <TextBox x:Name="TxtAveragePlaytime" Margin="0,0,0,10"/>
                        </StackPanel>
                    </Border>

                    <!-- Yeni Bölüm: Oyun Türleri ve Platformlar -->
                    <Border Background="#252530" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="🎮 Oyun Türleri ve Platformlar" Style="{StaticResource SectionHeader}" Foreground="White"/>
                            
                            <TextBlock Text="Oyun Türleri (Çoklu Seçim)"/>
                            <Border Background="#1A1A22" CornerRadius="6" Padding="12" Margin="0,0,0,10">
                                <StackPanel>
                                    <ItemsControl x:Name="GameGenresList">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#2A2A35" CornerRadius="16" Padding="12,6" Margin="0,0,8,8">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding}" Foreground="White" FontSize="13"/>
                                                        <Button Content="×" Background="Transparent" Foreground="#E74C3C" BorderThickness="0" 
                                                                FontSize="16" Padding="4,0,0,0" Margin="8,0,0,0" Cursor="Hand"
                                                                Click="RemoveGameGenre_Click" Tag="{Binding}"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <ComboBox x:Name="CmbGameGenre" Width="150" Background="#222228" Foreground="White" BorderBrush="#333" Padding="8,6">
                                            <ComboBoxItem Content="Ren'Py"/>
                                            <ComboBoxItem Content="Visual Novel"/>
                                            <ComboBoxItem Content="Sandbox"/>
                                            <ComboBoxItem Content="Adult"/>
                                            <ComboBoxItem Content="RPG"/>
                                            <ComboBoxItem Content="Dating Sim"/>
                                        </ComboBox>
                                        <Button x:Name="BtnAddGameGenre" Content="Ekle" Margin="8,0,0,0" Padding="12,6"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="Platformlar (Çoklu Seçim)"/>
                            <Border Background="#1A1A22" CornerRadius="6" Padding="12" Margin="0,0,0,10">
                                <StackPanel>
                                    <ItemsControl x:Name="PlatformsList">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#2A2A35" CornerRadius="16" Padding="12,6" Margin="0,0,8,8">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding}" Foreground="White" FontSize="13"/>
                                                        <Button Content="×" Background="Transparent" Foreground="#E74C3C" BorderThickness="0" 
                                                                FontSize="16" Padding="4,0,0,0" Margin="8,0,0,0" Cursor="Hand"
                                                                Click="RemovePlatform_Click" Tag="{Binding}"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <ComboBox x:Name="CmbPlatform" Width="150" Background="#222228" Foreground="White" BorderBrush="#333" Padding="8,6">
                                            <ComboBoxItem Content="Windows"/>
                                            <ComboBoxItem Content="Android"/>
                                            <ComboBoxItem Content="Linux"/>
                                            <ComboBoxItem Content="Mac"/>
                                        </ComboBox>
                                        <Button x:Name="BtnAddPlatform" Content="Ekle" Margin="8,0,0,0" Padding="12,6"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="İçerik Uyarıları (Çoklu Seçim)"/>
                            <Border Background="#1A1A22" CornerRadius="6" Padding="12" Margin="0,0,0,10">
                                <StackPanel>
                                    <ItemsControl x:Name="ContentWarningsList">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#2A2A35" CornerRadius="16" Padding="12,6" Margin="0,0,8,8">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding}" Foreground="White" FontSize="13"/>
                                                        <Button Content="×" Background="Transparent" Foreground="#E74C3C" BorderThickness="0" 
                                                                FontSize="16" Padding="4,0,0,0" Margin="8,0,0,0" Cursor="Hand"
                                                                Click="RemoveContentWarning_Click" Tag="{Binding}"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <ComboBox x:Name="CmbContentWarning" Width="150" Background="#222228" Foreground="White" BorderBrush="#333" Padding="8,6">
                                            <ComboBoxItem Content="+18"/>
                                            <ComboBoxItem Content="Şiddet"/>
                                            <ComboBoxItem Content="Küfür"/>
                                            <ComboBoxItem Content="Yetişkin İçerik"/>
                                        </ComboBox>
                                        <Button x:Name="BtnAddContentWarning" Content="Ekle" Margin="8,0,0,0" Padding="12,6"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Alt Bölüm: İndirme ve Ayarlar -->
                    <Border Background="#252530" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="🔗 İndirme ve Ayarlar" Style="{StaticResource SectionHeader}" Foreground="White"/>
                            <TextBlock Text="İndirme Linkleri (Etiket|URL formatında)"/>
                            <TextBox x:Name="TxtDownloadLinks" Height="50" AcceptsReturn="True" TextWrapping="Wrap"/>
                            
                            <TextBlock Text="Mod Dosyası (URL veya github:owner/repo/dosya.zip)"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBox x:Name="TxtPatch" Width="340"/>
                                <Button x:Name="BtnBrowsePatch" Content="Dosya Seç" Margin="8,0,0,0" Padding="12,6"/>
                            </StackPanel>

                            <TextBlock Text="Mod Notları"/>
                            <TextBox x:Name="TxtPatchNotes" Height="50" AcceptsReturn="True" TextWrapping="Wrap" Margin="0,0,0,10"/>
                            
                            <TextBlock Text="Özellikler" Margin="0,4,0,4"/>
                            <StackPanel Orientation="Horizontal">
                                <CheckBox x:Name="ChkIsVip" Content="VIP"/>
                                <CheckBox x:Name="ChkIsTop10" Content="Top 10"/>
                                <CheckBox x:Name="ChkIsFeatured" Content="Öne Çıkan"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button x:Name="BtnCancel" Content="İptal" Width="90" Margin="0,0,8,0" Padding="8"/>
                <Button x:Name="BtnSave" Content="Kaydet" Style="{StaticResource SaveBtn}" Width="100"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
