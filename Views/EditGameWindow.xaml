<Window x:Class="RenPyTRLauncher.Views.EditGameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Oyun Düzenle" Height="520" Width="540"
        Background="#0D0D0F" WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <SolidColorBrush x:Key="CardBrush" Color="#1A1A22"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#9B59FF"/>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#AAA"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#222228"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="0,0,16,0"/>
        </Style>
        <Style x:Key="SaveBtn" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource CardBrush}" CornerRadius="12" Margin="16" Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="🎮 Oyun Bilgileri" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,16"/>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="İsim"/>
                    <TextBox x:Name="TxtName"/>
                    <TextBlock Text="Açıklama"/>
                    <TextBox x:Name="TxtDesc"/>
                    <TextBlock Text="Versiyon"/>
                    <TextBox x:Name="TxtVersion"/>
                    <TextBlock Text="Yama Versiyonu"/>
                    <TextBox x:Name="TxtPatchVersion"/>
                    <TextBlock Text="Kategoriler (noktalı virgülle)"/>
                    <TextBox x:Name="TxtCategories"/>
                    <TextBlock Text="Kapak Görseli"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="TxtImage" Width="340"/>
                        <Button x:Name="BtnBrowseImage" Content="Gözat" Margin="8,0,0,10" Padding="12,6"/>
                    </StackPanel>
                    <TextBlock Text="Yama Kaynağı (URL veya github:owner/repo/dosya.zip)"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="TxtPatch" Width="340"/>
                        <Button x:Name="BtnBrowsePatch" Content="Dosya Seç" Margin="8,0,0,10" Padding="12,6"/>
                    </StackPanel>
                    <TextBlock Text="Etiketler" Margin="0,4,0,4"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <CheckBox x:Name="ChkIsVip" Content="VIP"/>
                        <CheckBox x:Name="ChkIsTop10" Content="Top 10"/>
                        <CheckBox x:Name="ChkIsFeatured" Content="Öne Çıkan"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button x:Name="BtnCancel" Content="İptal" Width="90" Margin="0,0,8,0" Padding="8"/>
                <Button x:Name="BtnSave" Content="Kaydet" Style="{StaticResource SaveBtn}" Width="100"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
