<Window x:Class="RenPyTRLauncher.Views.GameDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:RenPyTRLauncher.Data"
        Title="Oyun Detayı" Height="800" Width="1000" MinHeight="700" MinWidth="900"
        Background="#0D0D0F" WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <local:SafeImageConverter x:Key="SafeImage"/>
        <local:StringToBrushConverter x:Key="StringToBrush"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#9B59FF"/>
        <SolidColorBrush x:Key="CardBrush" Color="#1A1A22"/>
        <SolidColorBrush x:Key="SecondaryBrush" Color="#2A2A35"/>
        <DropShadowEffect x:Key="GlowEffect" Color="#9B59FF" Opacity="0.4" BlurRadius="15" ShadowDepth="0"/>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="24,14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12" Padding="{TemplateBinding Padding}" Effect="{StaticResource GlowEffect}">
                            <ContentPresenter HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(Button.RenderTransform).(ScaleTransform.ScaleX)"
                                               To="1.05" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(Button.RenderTransform).(ScaleTransform.ScaleY)"
                                               To="1.05" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(Button.RenderTransform).(ScaleTransform.ScaleX)"
                                               To="1" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(Button.RenderTransform).(ScaleTransform.ScaleY)"
                                               To="1" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                    <Setter Property="Background" Value="#8E44AD"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource SecondaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#3A3A45"/>
            <Setter Property="Padding" Value="24,14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(Button.RenderTransform).(ScaleTransform.ScaleX)"
                                               To="1.05" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(Button.RenderTransform).(ScaleTransform.ScaleY)"
                                               To="1.05" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(Button.RenderTransform).(ScaleTransform.ScaleX)"
                                               To="1" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(Button.RenderTransform).(ScaleTransform.ScaleY)"
                                               To="1" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                    <Setter Property="Background" Value="#3A3A45"/>
                    <Setter Property="BorderBrush" Value="#9B59FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid>
            <!-- Hero banner -->
            <Border Height="400" ClipToBounds="True">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#0D0D0F" Offset="0"/>
                        <GradientStop Color="#1A0A2E" Offset="0.3"/>
                        <GradientStop Color="#2D1B4E" Offset="0.7"/>
                        <GradientStop Color="#0D0D0F" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Image x:Name="ImgHero" Stretch="UniformToFill" Opacity="0.3"/>
                    <Border Background="#00000088"/>
                    <Grid Margin="48,40">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel VerticalAlignment="Bottom">
                            <TextBlock x:Name="TxtName" Foreground="White" FontSize="48" FontWeight="Bold" LineHeight="1.1"/>
                            <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                <Border Background="#9B59FF44" CornerRadius="8" Padding="14,8" Margin="0,0,12,0">
                                    <TextBlock x:Name="TxtVersion" Foreground="#9B59FF" FontSize="15" FontWeight="SemiBold"/>
                                </Border>
                                <Border Background="#33FFFFFF" CornerRadius="8" Padding="14,8" Margin="0,0,12,0">
                                    <TextBlock x:Name="TxtPatchVersion" Foreground="White" FontSize="15"/>
                                </Border>
                                <Border x:Name="BadgeVip" Background="#FFD70044" CornerRadius="8" Padding="14,8" Visibility="Collapsed">
                                    <TextBlock Text="💎 VIP" Foreground="#FFD700" FontSize="15" FontWeight="SemiBold"/>
                                </Border>
                                <Border x:Name="BadgeTurkish" CornerRadius="8" Padding="14,8" Margin="0,0,12,0">
                                    <TextBlock x:Name="TxtTurkish" Foreground="White" FontSize="15" FontWeight="SemiBold"/>
                                </Border>
                                <Border x:Name="BadgeSteam" CornerRadius="8" Padding="14,8" Margin="0,0,12,0">
                                    <TextBlock x:Name="TxtSteam" Foreground="White" FontSize="15" FontWeight="SemiBold"/>
                                </Border>
                                <Border x:Name="BadgeUpdate" CornerRadius="8" Padding="14,8" Margin="0,0,12,0">
                                    <TextBlock x:Name="TxtUpdate" Foreground="White" FontSize="15" FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                            <Button x:Name="BtnFavorite" Content="❤️ Favorilere Ekle" Width="200" Height="52" Margin="0,0,16,0"
                                    Background="#33FFFFFF" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnFavorite_Click" FontSize="15"/>
                            <Button x:Name="BtnDownloadGame" Content="⬇ Oyunu İndir" Style="{StaticResource SecondaryButton}" Height="52" Margin="0,0,16,0" Click="BtnDownloadGame_Click" FontSize="15"/>
                            <Button x:Name="BtnInstallPatch" Content="🇹🇷 Türkçe Modu İndir" Style="{StaticResource PrimaryButton}" Height="52" Click="BtnInstallPatch_Click" FontSize="15"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- Content below hero -->
            <StackPanel Margin="48,420,48,48">
                <!-- Cover Image Section -->
                <Border Background="#1A1A22" CornerRadius="16" Padding="24" Margin="0,0,0,40">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="300"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#0D0D0F" CornerRadius="12" ClipToBounds="True" Margin="0,0,24,0">
                            <Image x:Name="ImgCover" Stretch="UniformToFill"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="🎮 Oyun Kapak Resmi" Foreground="#9B59FF" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>
                            <TextBlock x:Name="TxtCoverInfo" Text="Kapak resmi yükleniyor..." Foreground="#888" FontSize="14" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Info Cards Section -->
                <Grid Margin="0,0,0,32">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#1A1A22" CornerRadius="12" Padding="20" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="⬇ İndirme" Foreground="#888" FontSize="12" Margin="0,0,0,4"/>
                            <TextBlock x:Name="TxtDownloadCountCard" Foreground="White" FontSize="18" FontWeight="SemiBold" Text="0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="#1A1A22" CornerRadius="12" Padding="20" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="📅 Güncelleme" Foreground="#888" FontSize="12" Margin="0,0,0,4"/>
                            <TextBlock x:Name="TxtUpdatedDateCard" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Background="#1A1A22" CornerRadius="12" Padding="20">
                        <StackPanel>
                            <TextBlock Text="🎮 Kategori" Foreground="#888" FontSize="12" Margin="0,0,0,4"/>
                            <TextBlock x:Name="TxtPrimaryCategory" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Description Section -->
                <TextBlock Text="📝 Açıklama" Foreground="#9B59FF" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                <Border Background="#1A1A22" CornerRadius="12" Padding="20" Margin="0,0,0,32">
                    <TextBlock x:Name="TxtDescription" Foreground="#C7D5E0" FontSize="15" TextWrapping="Wrap"/>
                </Border>

                <!-- Screenshots Gallery -->
                <TextBlock Text="🖼️ Ekran Görüntüleri" Foreground="#9B59FF" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="0,0,0,40">
                    <ItemsControl x:Name="ScreenshotList">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="320" Height="180" CornerRadius="12" Margin="0,0,20,20" ClipToBounds="True" Background="#1A1A22" Cursor="Hand"
                                        BorderThickness="2" BorderBrush="Transparent"
                                        MouseLeftButtonUp="Screenshot_MouseLeftButtonUp">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="BorderBrush" Value="#9B59FF"/>
                                                    <Setter Property="RenderTransform">
                                                <Setter.Value>
                                                    <ScaleTransform ScaleX="1.02" ScaleY="1.02" CenterX="160" CenterY="90"/>
                                                </Setter.Value>
                                            </Setter>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Image Source="{Binding Converter={StaticResource SafeImage}}" Stretch="UniformToFill"/>
                                        <Border Background="#00000066" VerticalAlignment="Bottom" Padding="12,8">
                                            <TextBlock Text="🔍 Büyüt" Foreground="White" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                <TextBlock x:Name="TxtNoScreenshots" Text="Henüz ekran görüntüsü eklenmemiş." Foreground="#666" FontSize="14" Margin="0,-20,0,40" Visibility="Collapsed"/>

                <!-- Two Column Layout for Patch Notes and Download Links -->
                <Grid Margin="0,0,0,32">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="📋 Mod Notları" Foreground="#9B59FF" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <Border Background="#1A1A22" CornerRadius="12" Padding="20">
                            <TextBlock x:Name="TxtPatchNotes" Foreground="#C7D5E0" FontSize="14" TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="16,0,0,0">
                        <TextBlock Text="🔗 İndirme Bağlantıları" Foreground="#9B59FF" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <ItemsControl x:Name="DownloadLinksList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding Label}" Tag="{Binding Url}" Click="DownloadLink_Click"
                                            Background="#2A2A35" Foreground="White" BorderThickness="1" BorderBrush="#3A3A45"
                                            Padding="16,12" Margin="0,0,0,8" HorizontalContentAlignment="Left" Cursor="Hand" Height="48"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock x:Name="TxtNoLinks" Text="Ek indirme bağlantısı yok." Foreground="#666" FontSize="14" Visibility="Collapsed"/>
                    </StackPanel>
                </Grid>

                <!-- System Information Section -->
                <TextBlock Text="⚙️ Sistem Bilgileri" Foreground="#9B59FF" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                <Border Background="#1A1A22" CornerRadius="12" Padding="20" Margin="0,0,0,32">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                            <TextBlock Text="Oyun Türü" Foreground="#888" FontSize="12" Margin="0,0,0,4"/>
                            <TextBlock x:Name="TxtGameType" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Türkçe Durumu" Foreground="#888" FontSize="12" Margin="0,0,0,4"/>
                            <TextBlock x:Name="TxtTurkishStatus" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Categories Section -->
                <TextBlock Text="🏷️ Kategoriler" Foreground="#9B59FF" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                <ItemsControl x:Name="CategoryTags" Margin="0,0,0,32">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#2A2A35" CornerRadius="8" Padding="14,8" Margin="0,0,10,10" Cursor="Hand">
                                <TextBlock Text="{Binding}" Foreground="White" FontSize="13"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- VIP Comments Section Placeholder -->
                <Border Background="#1A1A22" CornerRadius="12" Padding="20" Margin="0,0,0,32">
                    <StackPanel>
                        <TextBlock Text="💎 VIP Yorumları" Foreground="#FFD700" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <TextBlock Text="Bu özellik yakında eklenecek. VIP kullanıcıların oyun hakkındaki yorumları burada görüntülenecek." 
                                   Foreground="#666" FontSize="14" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>
