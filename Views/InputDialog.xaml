<Window x:Class="RenPyTRLauncher.Views.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Giriş" Height="180" Width="400"
        WindowStartupLocation="CenterOwner" Background="#0D0D0F" ResizeMode="NoResize">
    <Border Background="#1A1A22" CornerRadius="10" Margin="16" Padding="16">
        <StackPanel>
            <TextBlock x:Name="TxtPrompt" Foreground="White" Margin="0,0,0,10"/>
            <TextBox x:Name="TxtInput" Background="#222228" Foreground="White" Padding="8,6"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button Content="İptal" Width="80" Margin="0,0,8,0" Click="BtnCancel_Click"/>
                <Button Content="Tamam" Width="80" Click="BtnOk_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
