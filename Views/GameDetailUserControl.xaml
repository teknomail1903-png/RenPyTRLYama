<UserControl x:Class="RenPyTRLauncher.Views.GameDetailUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:RenPyTRLauncher.Data"
             Background="#0D0D0F">

    <UserControl.Resources>
        <local:SafeImageConverter x:Key="SafeImage"/>
        <local:StringToBrushConverter x:Key="StringToBrush"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#9B59FF"/>
        <SolidColorBrush x:Key="CardBrush" Color="#1A1A22"/>
        <SolidColorBrush x:Key="SecondaryBrush" Color="#2A2A35"/>
        <DropShadowEffect x:Key="GlowEffect" Color="#9B59FF" Opacity="0.4" BlurRadius="15" ShadowDepth="0"/>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="24,14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12" Padding="{TemplateBinding Padding}" Effect="{StaticResource GlowEffect}">
                            <ContentPresenter HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(Button.RenderTransform).(ScaleTransform.ScaleX)"
                                               To="1.05" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(Button.RenderTransform).(ScaleTransform.ScaleY)"
                                               To="1.05" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(Button.RenderTransform).(ScaleTransform.ScaleX)"
                                               To="1" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(Button.RenderTransform).(ScaleTransform.ScaleY)"
                                               To="1" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                    <Setter Property="Background" Value="#8E44AD"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource SecondaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#3A3A45"/>
            <Setter Property="Padding" Value="24,14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(Button.RenderTransform).(ScaleTransform.ScaleX)"
                                               To="1.05" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(Button.RenderTransform).(ScaleTransform.ScaleY)"
                                               To="1.05" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(Button.RenderTransform).(ScaleTransform.ScaleX)"
                                               To="1" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(Button.RenderTransform).(ScaleTransform.ScaleY)"
                                               To="1" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                    <Setter Property="Background" Value="#3A3A45"/>
                    <Setter Property="BorderBrush" Value="#9B59FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
        <StackPanel Margin="24,16,24,24">
            <!-- Top Row: Cover Image + Game Info -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Cover Image -->
                <Border Grid.Column="0" Background="#1A1A22" CornerRadius="8" Margin="0,0,16,0" Height="380" ClipToBounds="True">
                    <Image x:Name="ImgCover" Stretch="UniformToFill"/>
                </Border>

                <!-- Game Info -->
                <StackPanel Grid.Column="1" VerticalAlignment="Top">
                    <!-- Game Title -->
                    <TextBlock x:Name="TxtName" Foreground="White" FontSize="32" FontWeight="Bold" LineHeight="1.1" Margin="0,0,0,8"/>

                    <!-- Badges -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Background="#9B59FF44" CornerRadius="6" Padding="10,4" Margin="0,0,6,0">
                            <TextBlock x:Name="TxtVersion" Foreground="#9B59FF" FontSize="13" FontWeight="SemiBold"/>
                        </Border>
                        <Border Background="#33FFFFFF" CornerRadius="6" Padding="10,4" Margin="0,0,6,0">
                            <TextBlock x:Name="TxtPatchVersion" Foreground="White" FontSize="13"/>
                        </Border>
                        <Border x:Name="BadgeVip" Background="#FFD70044" CornerRadius="6" Padding="10,4" Visibility="Collapsed">
                            <TextBlock Text="💎 VIP" Foreground="#FFD700" FontSize="13" FontWeight="SemiBold"/>
                        </Border>
                        <Border x:Name="BadgeTurkish" CornerRadius="6" Padding="10,4" Margin="0,0,6,0">
                            <TextBlock x:Name="TxtTurkish" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                        </Border>
                        <Border x:Name="BadgeSteam" CornerRadius="6" Padding="10,4" Margin="0,0,6,0">
                            <TextBlock x:Name="TxtSteam" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                        </Border>
                        <Border x:Name="BadgeUpdate" CornerRadius="6" Padding="10,4" Margin="0,0,6,0">
                            <TextBlock x:Name="TxtUpdate" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>

                    <!-- Short Description Summary -->
                    <TextBlock x:Name="TxtDescription" Foreground="#C7D5E0" FontSize="14" TextWrapping="Wrap" Margin="0,0,0,12" MaxHeight="60" TextTrimming="WordEllipsis"/>

                    <!-- Action Buttons -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                        <Button x:Name="BtnFavorite" Content="❤️ Favorilere Ekle" Width="160" Height="44" Margin="0,0,8,0"
                                Background="#33FFFFFF" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnFavorite_Click" FontSize="13"/>
                        <Button x:Name="BtnDownloadGame" Content="⬇ İndir" Style="{StaticResource SecondaryButton}" Height="44" Margin="0,0,8,0" Click="BtnDownloadGame_Click" FontSize="13"/>
                        <Button x:Name="BtnInstallPatch" Content="🇹🇷 Türkçe Yama" Style="{StaticResource PrimaryButton}" Height="44" Click="BtnInstallPatch_Click" FontSize="13"/>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- Full Description -->
            <TextBlock Text="📝 Açıklama" Foreground="#9B59FF" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <Border Background="#1A1A22" CornerRadius="8" Padding="16" Margin="0,0,0,20">
                <TextBlock x:Name="TxtDescriptionFull" Foreground="#C7D5E0" FontSize="14" TextWrapping="Wrap"/>
            </Border>

            <!-- Statistics -->
            <TextBlock Text="📊 İstatistikler" Foreground="#9B59FF" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="#1A1A22" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="⬇ İndirme" Foreground="#888" FontSize="11" Margin="0,0,0,4"/>
                        <TextBlock x:Name="TxtDownloadCountCard" Foreground="White" FontSize="15" FontWeight="SemiBold" Text="0"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="#1A1A22" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="📅 Güncelleme" Foreground="#888" FontSize="11" Margin="0,0,0,4"/>
                        <TextBlock x:Name="TxtUpdatedDateCard" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Background="#1A1A22" CornerRadius="8" Padding="12">
                    <StackPanel>
                        <TextBlock Text="🎮 Kategori" Foreground="#888" FontSize="11" Margin="0,0,0,4"/>
                        <TextBlock x:Name="TxtPrimaryCategory" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Detailed Game Information -->
            <TextBlock Text="🎯 Detaylı Oyun Bilgileri" Foreground="#9B59FF" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <Border Background="#1A1A22" CornerRadius="8" Padding="16" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Row 1 -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,12">
                        <TextBlock Text="👨‍💻 Geliştirici" Foreground="#888" FontSize="11" Margin="0,0,0,4"/>
                        <TextBlock x:Name="TxtDeveloper" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,12">
                        <TextBlock Text="🏢 Yayıncı" Foreground="#888" FontSize="11" Margin="0,0,0,4"/>
                        <TextBlock x:Name="TxtPublisher" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                    </StackPanel>

                    <!-- Row 2 -->
                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,12">
                        <TextBlock Text="⚙️ Oyun Motoru" Foreground="#888" FontSize="11" Margin="0,0,0,4"/>
                        <TextBlock x:Name="TxtGameEngine" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,12">
                        <TextBlock Text="📅 Çıkış Tarihi" Foreground="#888" FontSize="11" Margin="0,0,0,4"/>
                        <TextBlock x:Name="TxtReleaseDate" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                    </StackPanel>

                    <!-- Row 3 -->
                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,12">
                        <TextBlock Text="✅ Tamamlanma Durumu" Foreground="#888" FontSize="11" Margin="0,0,0,4"/>
                        <TextBlock x:Name="TxtCompletionStatus" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,12">
                        <TextBlock Text="⏱️ Ortalama Süre" Foreground="#888" FontSize="11" Margin="0,0,0,4"/>
                        <TextBlock x:Name="TxtAveragePlaytime" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                    </StackPanel>

                    <!-- Row 4 - Game Genres -->
                    <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,12">
                        <TextBlock Text="🎮 Oyun Türleri" Foreground="#888" FontSize="11" Margin="0,0,0,4"/>
                        <ItemsControl x:Name="GameGenresList">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#2A2A35" CornerRadius="6" Padding="10,4" Margin="0,0,8,8">
                                        <TextBlock Text="{Binding}" Foreground="White" FontSize="12"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Row 5 - Platforms -->
                    <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,12">
                        <TextBlock Text="💻 Platformlar" Foreground="#888" FontSize="11" Margin="0,0,0,4"/>
                        <ItemsControl x:Name="PlatformsList">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#2A2A35" CornerRadius="6" Padding="10,4" Margin="0,0,8,8">
                                        <TextBlock Text="{Binding}" Foreground="White" FontSize="12"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Row 6 - Content Warnings -->
                    <StackPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2">
                        <TextBlock Text="⚠️ İçerik Uyarıları" Foreground="#888" FontSize="11" Margin="0,0,0,4"/>
                        <ItemsControl x:Name="ContentWarningsList">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#E74C3C22" CornerRadius="6" Padding="10,4" Margin="0,0,8,8" BorderThickness="1" BorderBrush="#E74C3C44">
                                        <TextBlock Text="{Binding}" Foreground="#E74C3C" FontSize="12" FontWeight="SemiBold"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Categories -->
            <TextBlock Text="🏷️ Kategoriler" Foreground="#9B59FF" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <ItemsControl x:Name="CategoryTags" Margin="0,0,0,20">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#2A2A35" CornerRadius="6" Padding="10,4" Margin="0,0,8,8" Cursor="Hand">
                            <TextBlock Text="{Binding}" Foreground="White" FontSize="12"/>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Tags -->
            <TextBlock Text="🏷️ Etiketler" Foreground="#9B59FF" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <ItemsControl x:Name="TagList" Margin="0,0,0,20">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#2A2A35" CornerRadius="14" Padding="10,4" Margin="0,0,8,8" Cursor="Hand"
                                BorderThickness="1" BorderBrush="#3A3A45"
                                MouseLeftButtonUp="Tag_Click">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#3A3A45"/>
                                            <Setter Property="BorderBrush" Value="#9B59FF"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding}" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Screenshots -->
            <TextBlock Text="🖼️ Ekran Görüntüleri" Foreground="#9B59FF" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="0,0,0,20">
                <ItemsControl x:Name="ScreenshotList">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="280" Height="160" CornerRadius="8" Margin="0,0,12,12" ClipToBounds="True" Background="#1A1A22" Cursor="Hand"
                                    BorderThickness="2" BorderBrush="Transparent"
                                    MouseLeftButtonUp="Screenshot_MouseLeftButtonUp">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="BorderBrush" Value="#9B59FF"/>
                                                <Setter Property="RenderTransform">
                                                <Setter.Value>
                                                    <ScaleTransform ScaleX="1.02" ScaleY="1.02" CenterX="140" CenterY="80"/>
                                                </Setter.Value>
                                            </Setter>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Image Source="{Binding Converter={StaticResource SafeImage}}" Stretch="UniformToFill"/>
                                        <Border Background="#00000066" VerticalAlignment="Bottom" Padding="8,4">
                                            <TextBlock Text="🔍 Büyüt" Foreground="White" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                <TextBlock x:Name="TxtNoScreenshots" Text="Henüz ekran görüntüsü eklenmemiş." Foreground="#666" FontSize="13" Margin="0,-12,0,20" Visibility="Collapsed"/>

            <!-- Patch Notes -->
            <TextBlock Text="📋 Yama Notları" Foreground="#9B59FF" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <Border Background="#1A1A22" CornerRadius="8" Padding="16" Margin="0,0,0,20">
                <TextBlock x:Name="TxtPatchNotes" Foreground="#C7D5E0" FontSize="14" TextWrapping="Wrap"/>
            </Border>

            <!-- Download Links -->
            <TextBlock Text="🔗 İndirme Bağlantıları" Foreground="#9B59FF" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <ItemsControl x:Name="DownloadLinksList" Margin="0,0,0,20">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Content="{Binding Label}" Tag="{Binding Url}" Click="DownloadLink_Click"
                                Background="#2A2A35" Foreground="White" BorderThickness="1" BorderBrush="#3A3A45"
                                Padding="12,8" Margin="0,0,0,8" HorizontalContentAlignment="Left" Cursor="Hand" Height="40" FontSize="13"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <TextBlock x:Name="TxtNoLinks" Text="Ek indirme bağlantısı yok." Foreground="#666" FontSize="13" Visibility="Collapsed"/>

            <!-- System Info -->
            <TextBlock Text="⚙️ Sistem Bilgileri" Foreground="#9B59FF" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <Border Background="#1A1A22" CornerRadius="8" Padding="16" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="Oyun Türü" Foreground="#888" FontSize="11" Margin="0,0,0,4"/>
                        <TextBlock x:Name="TxtGameType" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Türkçe Durumu" Foreground="#888" FontSize="11" Margin="0,0,0,4"/>
                        <TextBlock x:Name="TxtTurkishStatus" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- VIP Comments -->
            <Border Background="#1A1A22" CornerRadius="8" Padding="16">
                <StackPanel>
                    <TextBlock Text="💎 VIP Yorumları" Foreground="#FFD700" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBlock Text="Bu özellik yakında eklenecek. VIP kullanıcıların oyun hakkındaki yorumları burada görüntülenecek."
                               Foreground="#666" FontSize="13" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
