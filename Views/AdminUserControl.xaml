<UserControl x:Class="RenPyTRLauncher.Views.AdminUserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Height="500" Width="800">

    <Grid Background="#151516">
        <TabControl>
            <TabItem Header="📊 Dashboard">
                <StackPanel Margin="12">
                    <TextBlock Text="Dashboard" FontSize="18" Foreground="White" FontWeight="Bold"/>
                    <TextBlock Text="Sistemdeki oyun ve kullanıcı istatistikleri burada gösterilecek." Foreground="White" Margin="0,8"/>
                </StackPanel>
            </TabItem>
            <TabItem Header="🎮 Oyun Yönetimi">
                            <StackPanel Margin="12">
                    <Button x:Name="BtnAddGame" Content="Oyun Ekle" Width="120" Margin="0,10"/>

                    <ListBox x:Name="LstGames" DisplayMemberPath="Name" Height="220"/>

                    <StackPanel Orientation="Horizontal" Margin="0,10">
                        <Button x:Name="BtnEditGame" Content="Düzenle" Width="80" Margin="0,0,8,0"/>
                        <Button x:Name="BtnDeleteGame" Content="Sil" Width="80"/>
                    </StackPanel>
                </StackPanel>
            </TabItem>
            <TabItem Header="👥 Kullanıcı Yönetimi">
                <StackPanel Margin="12">
                    <TextBlock Text="Kullanıcılar" FontSize="16" Foreground="White" Margin="0,6"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ListBox x:Name="LstUsers" DisplayMemberPath="Username" Height="220" Grid.Column="0"/>
                        <StackPanel Orientation="Vertical" Grid.Column="1" Margin="8,0,0,0">
                            <Button x:Name="BtnUserAdd" Content="Ekle" Width="100" Margin="0,0,0,8"/>
                            <Button x:Name="BtnUserEdit" Content="Düzenle" Width="100" Margin="0,0,0,8"/>
                            <Button x:Name="BtnUserDelete" Content="Sil" Width="100" Margin="0,0,0,8"/>
                            <Button x:Name="BtnGrantVip" Content="VIP Ver" Width="100" Margin="0,0,0,8"/>
                            <Button x:Name="BtnRevokeVip" Content="VIP Kaldır" Width="100" Margin="0,0,0,8"/>
                            <Button x:Name="BtnExtendVip" Content="Süre Uzat" Width="100" Margin="0,0,0,8"/>
                            <Button x:Name="BtnMakeAdmin" Content="Admin Yap" Width="100" Margin="0,0,0,8"/>
                            <Button x:Name="BtnRevokeAdmin" Content="Admin Kaldır" Width="100"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </TabItem>
            <TabItem Header="💎 VIP Yönetimi">
                <StackPanel Margin="12">
                    <TextBlock Text="VIP yönetimi kullanıcı tablosundan da yönetilebilir." Foreground="White"/>
                </StackPanel>
            </TabItem>
            <TabItem Header="🏆 Top10 Yönetimi">
                <Grid Margin="12">
                    <Grid.Resources>
                        <SolidColorBrush x:Key="CardBg" Color="#222229"/>
                        <SolidColorBrush x:Key="Accent" Color="#9B59FF"/>
                        <Style x:Key="TopCard" TargetType="Border">
                            <Setter Property="Background" Value="{StaticResource CardBg}"/>
                            <Setter Property="CornerRadius" Value="8"/>
                            <Setter Property="Margin" Value="8"/>
                            <Setter Property="Padding" Value="8"/>
                            <Setter Property="Width" Value="220"/>
                            <Setter Property="Height" Value="280"/>
                        </Style>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Margin" Value="6"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border Background="Transparent">
                                            <ContentPresenter />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Grid.Resources>

                    <StackPanel>
                        <TextBlock Text="Top10 Oyunlar" FontSize="18" Foreground="White" FontWeight="Bold" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,8">
                            <Button x:Name="BtnTop10Refresh" Content="Yenile" Width="100" Margin="0,0,8,0"/>
                            <Button x:Name="BtnTop10Remove" Content="Kaldır" Width="100"/>
                        </StackPanel>

                        <ListBox x:Name="LstTop10" Height="360" ScrollViewer.HorizontalScrollBarVisibility="Disabled" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Top" AlternationCount="1000">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource CardBg}" CornerRadius="8" Margin="8" Padding="8" Width="220" Height="280">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="140"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <Grid>
                                                <Image Source="{Binding ImagePath}" Stretch="UniformToFill" />
                                                <Border Background="#00000066" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="8" Padding="4" CornerRadius="4">
                                                    <TextBlock Foreground="White" FontWeight="Bold" FontSize="14">
                                                        <TextBlock.Text>
                                                            <MultiBinding StringFormat="# {0}">
                                                                <Binding RelativeSource="{RelativeSource AncestorType=ListBoxItem}" Path="(ItemsControl.AlternationIndex)" />
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                </Border>
                                            </Grid>

                                            <StackPanel Grid.Row="1" Margin="6">
                                                <TextBlock Text="{Binding Name}" Foreground="White" FontWeight="SemiBold" FontSize="14" TextTrimming="CharacterEllipsis" />
                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                    <TextBlock Text="Versiyon: " Foreground="LightGray" FontSize="12"/>
                                                    <TextBlock Text="{Binding Version}" Foreground="LightGray" FontSize="12"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                    <TextBlock Text="⬇" FontSize="12" Margin="0,0,6,0"/>
                                                    <TextBlock Text="{Binding DownloadCount}" Foreground="White" FontSize="12"/>
                                                    <TextBlock Text="   ★" FontSize="12" Margin="12,0,6,0"/>
                                                    <TextBlock Text="0" Foreground="White" FontSize="12"/>
                                                </StackPanel>
                                                <Button Content="Detay" HorizontalAlignment="Right" Width="80" Margin="0,8,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Grid>
            </TabItem>
            <TabItem Header="📢 Duyuru Yönetimi">
                <StackPanel Margin="12">
                    <TextBlock Text="Duyurular" FontSize="18" Foreground="White" FontWeight="Bold"/>
                    <ListBox x:Name="LstAnns" DisplayMemberPath="Title" Height="200"/>
                    <TextBlock Text="Başlık" Foreground="White" Margin="0,8,0,0"/>
                    <TextBox x:Name="TxtAnnTitle" Margin="0,2,0,0"/>
                    <TextBlock Text="Mesaj" Foreground="White" Margin="0,8,0,0"/>
                    <TextBox x:Name="TxtAnnMsg" Height="80" AcceptsReturn="True" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Button x:Name="BtnAddAnn" Content="Duyuru Ekle" Width="120" Margin="0,0,8,0"/>
                        <Button x:Name="BtnDeleteAnn" Content="Duyuru Sil" Width="120"/>
                    </StackPanel>
                </StackPanel>
            </TabItem>
            <TabItem Header="⚙ Sistem Ayarları">
                <StackPanel Margin="12">
                    <TextBlock Text="Sistem Ayarları" FontSize="18" Foreground="White" FontWeight="Bold"/>
                    <TextBlock Text="Burada temel yapılandırma ayarları yer alır." Foreground="White" Margin="0,8"/>
                </StackPanel>
            </TabItem>
        </TabControl>
            </Grid>
        </UserControl>
