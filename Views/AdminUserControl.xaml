<UserControl x:Class="RenPyTRLauncher.Views.AdminUserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#0D0D0F">

    <UserControl.Resources>
        <SolidColorBrush x:Key="CardBg" Color="#1A1A22"/>
        <SolidColorBrush x:Key="Accent" Color="#9B59FF"/>
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBg}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,12,12"/>
            <Setter Property="MinWidth" Value="160"/>
        </Style>
        <Style x:Key="AdminLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="AdminValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="8">
        <TabControl Background="Transparent" BorderThickness="0">
            <TabItem Header="📊 Dashboard">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">
                        <TextBlock Text="Dashboard" FontSize="22" Foreground="White" FontWeight="Bold" Margin="0,0,0,16"/>
                        <WrapPanel x:Name="DashboardStats">
                            <Border Style="{StaticResource StatCard}">
                                <StackPanel>
                                    <TextBlock Text="🎮 Toplam Oyun" Style="{StaticResource AdminLabel}"/>
                                    <TextBlock x:Name="TxtStatGames" Style="{StaticResource AdminValue}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource StatCard}">
                                <StackPanel>
                                    <TextBlock Text="👥 Toplam Kullanıcı" Style="{StaticResource AdminLabel}"/>
                                    <TextBlock x:Name="TxtStatUsers" Style="{StaticResource AdminValue}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource StatCard}">
                                <StackPanel>
                                    <TextBlock Text="⬇ Toplam İndirme" Style="{StaticResource AdminLabel}"/>
                                    <TextBlock x:Name="TxtStatDownloads" Style="{StaticResource AdminValue}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource StatCard}">
                                <StackPanel>
                                    <TextBlock Text="💎 VIP Üye" Style="{StaticResource AdminLabel}"/>
                                    <TextBlock x:Name="TxtStatVip" Style="{StaticResource AdminValue}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource StatCard}">
                                <StackPanel>
                                    <TextBlock Text="📥 Aktif İndirme" Style="{StaticResource AdminLabel}"/>
                                    <TextBlock x:Name="TxtStatActive" Style="{StaticResource AdminValue}"/>
                                </StackPanel>
                            </Border>
                        </WrapPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem x:Name="TabGames" Header="🎮 Oyun Yönetimi">
                <StackPanel Margin="12">
                    <Button x:Name="BtnAddGame" Content="+ Oyun Ekle" Width="140" Height="36" Margin="0,0,0,10"/>
                    <ListBox x:Name="LstGames" DisplayMemberPath="Name" Height="280" Background="#1A1A22" Foreground="White" BorderThickness="0"/>
                    <StackPanel Orientation="Horizontal" Margin="0,10">
                        <Button x:Name="BtnEditGame" Content="Düzenle" Width="100" Margin="0,0,8,0"/>
                        <Button x:Name="BtnDeleteGame" Content="Sil" Width="100"/>
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <TabItem x:Name="TabUsers" Header="👥 Kullanıcı Yönetimi">
                <StackPanel Margin="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ListBox x:Name="LstUsers" DisplayMemberPath="Username" Height="280" Background="#1A1A22" Foreground="White" BorderThickness="0"/>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <Button x:Name="BtnUserAdd" Content="Ekle" Width="110" Margin="0,0,0,8"/>
                            <Button x:Name="BtnUserEdit" Content="Düzenle" Width="110" Margin="0,0,0,8"/>
                            <Button x:Name="BtnUserDelete" Content="Sil" Width="110" Margin="0,0,0,8"/>
                            <Button x:Name="BtnGrantVip" Content="VIP Ver" Width="110" Margin="0,0,0,8"/>
                            <Button x:Name="BtnRevokeVip" Content="VIP Kaldır" Width="110" Margin="0,0,0,8"/>
                            <Button x:Name="BtnExtendVip" Content="Süre Uzat" Width="110" Margin="0,0,0,8"/>
                            <Button x:Name="BtnMakeAdmin" Content="Admin Yap" Width="110" Margin="0,0,0,8"/>
                            <Button x:Name="BtnRevokeAdmin" Content="Admin Kaldır" Width="110" Margin="0,0,0,8"/>
                            <Button x:Name="BtnMakeMod" Content="Mod Yap" Width="110" Margin="0,0,0,8"/>
                            <Button x:Name="BtnRevokeMod" Content="Mod Kaldır" Width="110"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </TabItem>

            <TabItem x:Name="TabSupport" Header="🆘 Destek Talepleri">
                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="320"/>
                    </Grid.ColumnDefinitions>
                    <ListBox x:Name="LstTickets" Height="400" Background="#1A1A22" Foreground="White" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="4">
                                    <TextBlock>
                                        <Run Text="{Binding TypeLabel, Mode=OneWay}" Foreground="#9B59FF"/>
                                        <Run Text=" — "/>
                                        <Run Text="{Binding Subject, Mode=OneWay}" FontWeight="SemiBold"/>
                                        <Run Text=" ["/>
                                        <Run Text="{Binding StatusLabel, Mode=OneWay}"/>
                                        <Run Text="]"/>
                                    </TextBlock>
                                    <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}" Foreground="#666" FontSize="11"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                        <TextBlock Text="Talep Detayı" Foreground="White" FontWeight="Bold" Margin="0,0,0,8"/>
                        <TextBlock x:Name="TxtTicketDetail" Foreground="#CCC" TextWrapping="Wrap" Height="120" Margin="0,0,0,10"/>
                        <TextBlock Text="Admin Yanıtı" Foreground="#888" FontSize="12"/>
                        <TextBox x:Name="TxtTicketReply" Height="80" AcceptsReturn="True" TextWrapping="Wrap" Margin="0,4,0,10"/>
                        <Button x:Name="BtnReplyTicket" Content="Yanıtla" Width="110" Margin="0,0,0,8"/>
                        <Button x:Name="BtnCloseTicket" Content="Kapat" Width="110" Margin="0,0,0,8"/>
                        <Button x:Name="BtnReopenTicket" Content="Yeniden Aç" Width="110"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem x:Name="TabMemberships" Header="💎 Üyelik Kartları">
                <StackPanel Margin="12">
                    <TextBlock Text="VIP üyelik planlarını buradan yönetin." Foreground="#888" Margin="0,0,0,10"/>
                    <ListBox x:Name="LstMemberships" Height="200" Background="#1A1A22" Foreground="White" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Icon}" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                    <TextBlock Text=" — " Foreground="#666"/>
                                    <TextBlock Text="{Binding PriceLabel}" Foreground="{StaticResource Accent}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Ad" Foreground="White" FontSize="12"/>
                            <TextBox x:Name="TxtTierName" Margin="0,4,0,8"/>
                            <TextBlock Text="Fiyat Etiketi" Foreground="White" FontSize="12"/>
                            <TextBox x:Name="TxtTierPrice" Margin="0,4,0,8"/>
                            <TextBlock Text="Satın Al URL" Foreground="White" FontSize="12"/>
                            <TextBox x:Name="TxtTierUrl" Margin="0,4,0,8"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Özellikler (satır başına bir)" Foreground="White" FontSize="12"/>
                            <TextBox x:Name="TxtTierFeatures" Height="100" AcceptsReturn="True" TextWrapping="Wrap" Margin="0,4,0,8"/>
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="BtnSaveTier" Content="Kaydet" Width="100" Margin="0,0,8,0"/>
                                <Button x:Name="BtnDeleteTier" Content="Sil" Width="100"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </TabItem>

            <TabItem x:Name="TabTop10" Header="🏆 Top10 Yönetimi">
                <StackPanel Margin="12">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,8">
                        <Button x:Name="BtnTop10Refresh" Content="Yenile" Width="100" Margin="0,0,8,0"/>
                        <Button x:Name="BtnTop10Remove" Content="Kaldır" Width="100"/>
                    </StackPanel>
                    <ListBox x:Name="LstTop10" Height="360" ScrollViewer.HorizontalScrollBarVisibility="Disabled" AlternationCount="1000">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1A1A22" CornerRadius="10" Margin="8" Padding="8" Width="200" Height="240">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="120"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <Grid>
                                            <Image Source="{Binding ImagePath}" Stretch="UniformToFill"/>
                                            <Border Background="#00000088" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="6" Padding="6,3" CornerRadius="6">
                                                <TextBlock Foreground="White" FontWeight="Bold">
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="# {0}">
                                                            <Binding RelativeSource="{RelativeSource AncestorType=ListBoxItem}" Path="(ItemsControl.AlternationIndex)"/>
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </Border>
                                        </Grid>
                                        <StackPanel Grid.Row="1" Margin="4">
                                            <TextBlock Text="{Binding Name}" Foreground="White" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Foreground="#888" FontSize="11">
                                                <Run Text="⬇ "/><Run Text="{Binding DownloadCount}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </TabItem>

            <TabItem x:Name="TabAnnouncements" Header="📢 Duyuru Yönetimi">
                <StackPanel Margin="12">
                    <ListBox x:Name="LstAnns" DisplayMemberPath="Title" Height="160" Background="#1A1A22" Foreground="White" BorderThickness="0"/>
                    <TextBlock Text="Başlık" Foreground="White" Margin="0,10,0,2"/>
                    <TextBox x:Name="TxtAnnTitle"/>
                    <TextBlock Text="Mesaj" Foreground="White" Margin="0,8,0,2"/>
                    <TextBox x:Name="TxtAnnMsg" Height="60" AcceptsReturn="True" TextWrapping="Wrap"/>
                    <TextBlock Text="Renk (#hex)" Foreground="White" Margin="0,8,0,2"/>
                    <TextBox x:Name="TxtAnnColor" Text="#9B59FF"/>
                    <CheckBox x:Name="ChkAnnPinned" Content="📌 Sabitle (Ana sayfada öncelikli)" Foreground="White" Margin="0,8,0,0"/>
                    <StackPanel Orientation="Horizontal" Margin="0,10">
                        <Button x:Name="BtnAddAnn" Content="Duyuru Ekle" Width="120" Margin="0,0,8,0"/>
                        <Button x:Name="BtnUpdateAnn" Content="Güncelle" Width="100" Margin="0,0,8,0"/>
                        <Button x:Name="BtnDeleteAnn" Content="Duyuru Sil" Width="120"/>
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <TabItem x:Name="TabCategories" Header="📁 Kategoriler">
                <StackPanel Margin="12">
                    <Button x:Name="BtnAddCategory" Content="+ Kategori Ekle" Width="140" Height="36" HorizontalAlignment="Left" Margin="0,0,0,10"/>
                    <ListBox x:Name="LstCategories" Height="280" Background="#1A1A22" Foreground="White" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Icon}" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                    <TextBlock Text=" — " Foreground="#666"/>
                                    <TextBlock Text="{Binding Name}" Foreground="#888"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <StackPanel Orientation="Horizontal" Margin="0,10">
                        <Button x:Name="BtnEditCategory" Content="Düzenle" Width="100" Margin="0,0,8,0"/>
                        <Button x:Name="BtnDeleteCategory" Content="Sil" Width="100"/>
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <TabItem x:Name="TabHelp" Header="📚 Rehber Yönetimi">
                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <ListBox x:Name="LstHelpGuides" Height="200" Background="#1A1A22" Foreground="White" BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding TypeIcon}" Margin="0,0,6,0"/>
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button x:Name="BtnDeleteHelp" Content="Sil" Width="80"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Başlık" Foreground="White" FontSize="12"/>
                        <TextBox x:Name="TxtHelpTitle" Margin="0,4,0,8"/>
                        <TextBlock Text="İçerik" Foreground="White" FontSize="12"/>
                        <TextBox x:Name="TxtHelpContent" Height="80" AcceptsReturn="True" TextWrapping="Wrap" Margin="0,4,0,8"/>
                        <TextBlock Text="Video URL (video rehberler için)" Foreground="White" FontSize="12"/>
                        <TextBox x:Name="TxtHelpVideoUrl" Margin="0,4,0,8"/>
                        <TextBlock Text="Tür" Foreground="White" FontSize="12"/>
                        <ComboBox x:Name="CmbHelpType" Margin="0,4,0,8">
                            <ComboBoxItem Content="Yazılı Rehber" Tag="Text"/>
                            <ComboBoxItem Content="Video Rehber" Tag="Video"/>
                            <ComboBoxItem Content="SSS" Tag="FAQ"/>
                            <ComboBoxItem Content="Araç" Tag="Tool"/>
                        </ComboBox>
                        <Button x:Name="BtnAddHelp" Content="Rehber Ekle" Width="120" Height="32"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem x:Name="TabSettings" Header="⚙ Bağlantı Ayarları">
                <StackPanel Margin="12" MaxWidth="500">
                    <TextBlock Text="Launcher bağlantı ayarları" Foreground="White" FontWeight="Bold" Margin="0,0,0,12"/>
                    <TextBlock Text="Web Sitesi URL" Foreground="#888" FontSize="12"/>
                    <TextBox x:Name="TxtWebsiteUrl" Margin="0,4,0,10"/>
                    <TextBlock Text="Discord URL" Foreground="#888" FontSize="12"/>
                    <TextBox x:Name="TxtDiscordUrl" Margin="0,4,0,10"/>
                    <TextBlock Text="Duyurular URL" Foreground="#888" FontSize="12"/>
                    <TextBox x:Name="TxtAnnouncementsUrl" Margin="0,4,0,10"/>
                    <TextBlock Text="Destek URL" Foreground="#888" FontSize="12"/>
                    <TextBox x:Name="TxtSupportUrl" Margin="0,4,0,10"/>
                    <Button x:Name="BtnSaveSettings" Content="Ayarları Kaydet" Width="160" Height="36" Margin="0,8,0,0"/>
                </StackPanel>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
