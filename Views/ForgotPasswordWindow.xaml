<Window x:Class="RenPyTRLauncher.Views.ForgotPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RenPy TR Launcher — Şifremi Unuttum"
        Height="550" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#0A0A0C"
        WindowStyle="None"
        AllowsTransparency="True">

    <Window.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#9B59FF"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#8E44FF"/>
        <SolidColorBrush x:Key="CardBrush" Color="#1A1A22"/>
        <SolidColorBrush x:Key="InputBrush" Color="#25252D"/>
        <SolidColorBrush x:Key="InputBorderBrush" Color="#3A3A45"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#A0A0A8"/>
        <SolidColorBrush x:Key="TextMuted" Color="#6A6A75"/>

        <DropShadowEffect x:Key="WindowShadow" BlurRadius="30" ShadowDepth="0" Opacity="0.4" Color="#000"/>
        <DropShadowEffect x:Key="ButtonShadow" BlurRadius="12" ShadowDepth="0" Opacity="0.3" Color="#9B59FF"/>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="{StaticResource InputBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Effect" Value="{StaticResource ButtonShadow}"/>
        </Style>

        <Style x:Key="SecondaryBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource CardBrush}"
            CornerRadius="16"
            Effect="{StaticResource WindowShadow}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="50,50,50,50">
                <!-- Step 1: Email -->
                <StackPanel x:Name="Step1Panel">
                    <TextBlock Text="Şifremi Unuttum" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,8"/>
                    <TextBlock Text="E-posta adresinizi girin, şifre sıfırlama işlemini başlatalım." FontSize="14" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" Margin="0,0,0,32"/>

                    <TextBlock Text="E-posta Adresi" Foreground="{StaticResource TextSecondary}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBox x:Name="TxtEmail"/>

                    <Button x:Name="BtnStep1Continue" Content="Devam Et" Style="{StaticResource PrimaryBtn}" Margin="0,0,0,12" Click="BtnStep1Continue_Click"/>
                    <Button x:Name="BtnBack" Content="Giriş Ekranına Dön" Style="{StaticResource SecondaryBtn}" Click="BtnBack_Click"/>
                </StackPanel>

                <!-- Step 2: Secret Question -->
                <StackPanel x:Name="Step2Panel" Visibility="Collapsed">
                    <TextBlock Text="Gizli Soru Doğrulama" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,8"/>
                    <TextBlock Text="Gizli sorunuzu doğru cevaplayarak şifrenizi sıfırlayın." FontSize="14" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" Margin="0,0,0,32"/>

                    <TextBlock x:Name="LblSecretQuestion" Text="Gizli Soru" Foreground="{StaticResource TextSecondary}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <Border Background="#2D1B4E" CornerRadius="8" Padding="16" Margin="0,0,0,20">
                        <TextBlock x:Name="TxtSecretQuestionDisplay" Text="" Foreground="{StaticResource TextPrimary}" FontSize="14" FontWeight="SemiBold"/>
                    </Border>

                    <TextBlock Text="Gizli Cevap" Foreground="{StaticResource TextSecondary}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBox x:Name="TxtSecretAnswer"/>

                    <Button x:Name="BtnStep2Continue" Content="Cevabı Doğrula" Style="{StaticResource PrimaryBtn}" Margin="0,0,0,12" Click="BtnStep2Continue_Click"/>
                    <Button x:Name="BtnStep2Back" Content="Geri Dön" Style="{StaticResource SecondaryBtn}" Click="BtnStep2Back_Click"/>
                </StackPanel>

                <!-- Step 3: New Password -->
                <StackPanel x:Name="Step3Panel" Visibility="Collapsed">
                    <TextBlock Text="Yeni Şifre Belirle" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,8"/>
                    <TextBlock Text="Yeni şifrenizi belirleyin (minimum 6 karakter)." FontSize="14" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" Margin="0,0,0,32"/>

                    <TextBlock Text="Yeni Şifre" Foreground="{StaticResource TextSecondary}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <PasswordBox x:Name="TxtNewPassword"/>

                    <TextBlock Text="Yeni Şifre (Tekrar)" Foreground="{StaticResource TextSecondary}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <PasswordBox x:Name="TxtNewPasswordConfirm"/>

                    <Button x:Name="BtnStep3Continue" Content="Şifreyi Güncelle" Style="{StaticResource PrimaryBtn}" Margin="0,0,0,12" Click="BtnStep3Continue_Click"/>
                    <Button x:Name="BtnStep3Back" Content="Geri Dön" Style="{StaticResource SecondaryBtn}" Click="BtnStep3Back_Click"/>
                </StackPanel>

                <!-- Step 4: Success -->
                <StackPanel x:Name="Step4Panel" Visibility="Collapsed">
                    <TextBlock Text="✅ Başarılı" FontSize="28" FontWeight="Bold" Foreground="#10B981" Margin="0,0,0,8"/>
                    <TextBlock Text="Şifreniz başarıyla güncellendi. Artık yeni şifrenizle giriş yapabilirsiniz." FontSize="14" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" Margin="0,0,0,32"/>

                    <Button x:Name="BtnStep4Finish" Content="Giriş Ekranına Dön" Style="{StaticResource PrimaryBtn}" Click="BtnStep4Finish_Click"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>
