<UserControl x:Class="RenPyTRLauncher.Views.SupportUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1A1A22" CornerRadius="12" Padding="24" Margin="0,0,0,24">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="📋 Destek Merkezi" FontSize="24" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Destek taleplerinizi buradan yönetebilirsiniz" FontSize="14" Foreground="#888" Margin="0,4,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" x:Name="BtnNewTicket" Content="+ Yeni Talep" 
                        Background="#9B59FF" Foreground="White" BorderThickness="0" 
                        Padding="20,12" FontWeight="SemiBold" FontSize="14" Cursor="Hand"
                        Click="BtnNewTicket_Click"/>
            </Grid>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel - Ticket List -->
            <Border Grid.Column="0" Background="#1A1A22" CornerRadius="12" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Taleplerim" FontSize="16" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,12"/>
                    
                    <Border Grid.Row="1" Background="#0F1420" CornerRadius="8" Padding="12,8" Margin="0,0,0,12">
                        <Grid>
                            <TextBlock Text="🔍 Ara..." Foreground="#666" FontSize="13" VerticalAlignment="Center" IsHitTestVisible="False" Margin="0,0,0,0"/>
                            <TextBox x:Name="TxtSearch" Background="Transparent" BorderThickness="0" Foreground="White" FontSize="13" Padding="0" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <ListBox x:Name="LstTickets" Grid.Row="2" Background="Transparent" BorderThickness="0" 
                             SelectionMode="Single" SelectionChanged="LstTickets_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#25252D" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Subject}" FontWeight="SemiBold" Foreground="White" 
                                                   TextTrimming="CharacterEllipsis" FontSize="13"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <Border Background="#2D3748" CornerRadius="4" Padding="6,2">
                                                <TextBlock Text="{Binding StatusLabel}" FontSize="10" FontWeight="SemiBold" Foreground="#A0A5B8"/>
                                            </Border>
                                            <TextBlock Text=" • " FontSize="10" Foreground="#6B7280" Margin="4,0"/>
                                            <TextBlock Text="{Binding CreatedAt, StringFormat=dd.MM.yyyy}" FontSize="10" Foreground="#A0A5B8"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Right Panel - Ticket Details -->
            <Border Grid.Column="1" Background="#1A1A22" CornerRadius="12" Padding="24" Margin="16,0,0,0">
                <Grid x:Name="TicketDetailsPanel">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Ticket Header -->
                    <StackPanel Grid.Row="0" x:Name="TicketHeaderPanel" Visibility="Collapsed">
                        <TextBlock x:Name="TxtSubject" Text="" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Border Background="#2D3748" CornerRadius="4" Padding="8,4">
                                <TextBlock x:Name="TxtStatus" Text="" FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                            </Border>
                            <TextBlock Text=" • " FontSize="12" Foreground="#6B7280" Margin="4,0"/>
                            <TextBlock x:Name="TxtType" Text="" FontSize="12" Foreground="#A0A5B8"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Messages -->
                    <ScrollViewer Grid.Row="1" x:Name="MessagesScrollViewer" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="MessagesPanel"/>
                    </ScrollViewer>

                    <!-- Reply Input -->
                    <StackPanel Grid.Row="2" x:Name="ReplyPanel" Visibility="Collapsed" Margin="0,16,0,0">
                        <TextBox x:Name="TxtReply" Height="80" TextWrapping="Wrap" AcceptsReturn="True" 
                                 VerticalScrollBarVisibility="Auto" Background="#0F1420" Foreground="White"
                                 BorderBrush="#2D3748" BorderThickness="1" Padding="12" Margin="0,0,0,12"/>
                        <Button x:Name="BtnSendReply" Content="Gönder" Background="#9B59FF" Foreground="White" 
                                BorderThickness="0" Padding="20,12" FontWeight="SemiBold" FontSize="14" Cursor="Hand"
                                HorizontalAlignment="Right" Click="BtnSendReply_Click"/>
                    </StackPanel>

                    <!-- New Ticket Form -->
                    <StackPanel Grid.Row="0" Grid.RowSpan="3" x:Name="NewTicketPanel" Visibility="Collapsed">
                        <TextBlock Text="Yeni Destek Talebi" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,20"/>
                        
                        <TextBlock Text="Konu" Foreground="#A0A5B8" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBox x:Name="TxtNewSubject" Background="#0F1420" Foreground="White" BorderBrush="#2D3748" BorderThickness="1" Padding="12" Height="42" Margin="0,0,0,16"/>

                        <TextBlock Text="Talep Türü" Foreground="#A0A5B8" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <ComboBox x:Name="CmbTicketType" Background="#0F1420" Foreground="White" BorderBrush="#2D3748" BorderThickness="1" Padding="12" Height="42" Margin="0,0,0,16"/>

                        <TextBlock Text="Mesaj" Foreground="#A0A5B8" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBox x:Name="TxtNewMessage" Height="120" TextWrapping="Wrap" AcceptsReturn="True" 
                                 VerticalScrollBarVisibility="Auto" Background="#0F1420" Foreground="White"
                                 BorderBrush="#2D3748" BorderThickness="1" Padding="12" Margin="0,0,0,20"/>

                        <Button x:Name="BtnSubmitTicket" Content="Talep Oluştur" Background="#9B59FF" Foreground="White" 
                                BorderThickness="0" Padding="20,12" FontWeight="SemiBold" FontSize="14" Cursor="Hand"
                                HorizontalAlignment="Right" Click="BtnSubmitTicket_Click"/>
                    </StackPanel>

                    <!-- Empty State -->
                    <StackPanel Grid.Row="0" Grid.RowSpan="3" x:Name="EmptyPanel" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="📋" FontSize="48" HorizontalAlignment="Center" Foreground="#6B7280"/>
                        <TextBlock Text="Bir destek talebi seçin" FontSize="14" Foreground="#A0A5B8" 
                                   HorizontalAlignment="Center" Margin="0,12,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
