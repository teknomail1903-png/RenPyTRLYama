<Window x:Class="RenPyTRLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:RenPyTRLauncher.Data"
        Title="RenPyTR Launcher"
        Height="800"
        Width="1360"
        MinHeight="640"
        MinWidth="1024"
        Background="#0D0D0F"
        Closing="Window_Closing">

    <Window.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <local:StringToBrushConverter x:Key="StringToBrush"/>
        <local:SafeImageConverter x:Key="SafeImage"/>
        <local:AvatarImageConverter x:Key="AvatarImage"/>
        <local:CountToVisibilityConverter x:Key="CountToVis"/>
        <local:RoleToVisibilityConverter x:Key="RoleToVis"/>
        <local:StringNotEmptyToVisibilityConverter x:Key="StrNotEmpty"/>

        <!-- Card Shadow Effect -->
        <DropShadowEffect x:Key="CardShadow" Color="Black" Opacity="0.3" BlurRadius="20" ShadowDepth="4"/>

        <!-- Sidebar Button Style -->
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E8E8F0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="18,14"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(Button.RenderTransform).(ScaleTransform.ScaleX)"
                                                           To="1.05" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetProperty="(Button.RenderTransform).(ScaleTransform.ScaleY)"
                                                           To="1.05" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(Button.RenderTransform).(ScaleTransform.ScaleX)"
                                                           To="1" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetProperty="(Button.RenderTransform).(ScaleTransform.ScaleY)"
                                                           To="1" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                                <Setter TargetName="Border" Property="Background" Value="#2A2A35"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sidebar Active Button Style -->
        <Style x:Key="SidebarActiveButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#9B59FF33"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="18,14"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="LeftIndicator" Width="4" Background="#9B59FF" CornerRadius="0,4,4,0" HorizontalAlignment="Left" Margin="0,0,0,0"/>
                            <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="12" Padding="{TemplateBinding Padding}" Margin="8,0,0,0">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Logout Button Style -->
        <Style x:Key="SidebarLogoutButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#E74C3C22"/>
            <Setter Property="Foreground" Value="#E74C3C"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="18,14"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(Button.RenderTransform).(ScaleTransform.ScaleX)"
                                                           To="1.05" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetProperty="(Button.RenderTransform).(ScaleTransform.ScaleY)"
                                                           To="1.05" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(Button.RenderTransform).(ScaleTransform.ScaleX)"
                                                           To="1" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetProperty="(Button.RenderTransform).(ScaleTransform.ScaleY)"
                                                           To="1" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                                <Setter TargetName="Border" Property="Background" Value="#E74C3C"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- VIP Card Base Style -->
        <Style x:Key="VipCardBaseStyle" TargetType="Border">
            <Setter Property="Width" Value="280"/>
            <Setter Property="MinHeight" Value="380"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Margin" Value="0,0,24,24"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Bronze VIP Card Style -->
        <Style x:Key="VipCardBronzeStyle" TargetType="Border" BasedOn="{StaticResource VipCardBaseStyle}">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#CD7F32" Offset="0"/>
                        <GradientStop Color="#8B4513" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="#CD7F32"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#CD7F32" Opacity="0.4" BlurRadius="20" ShadowDepth="4"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleX)"
                                               To="1.05" Duration="0:0:0.25"/>
                                <DoubleAnimation Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleY)"
                                               To="1.05" Duration="0:0:0.25"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleX)"
                                               To="1" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleY)"
                                               To="1" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Silver VIP Card Style -->
        <Style x:Key="VipCardSilverStyle" TargetType="Border" BasedOn="{StaticResource VipCardBaseStyle}">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#C0C0C0" Offset="0"/>
                        <GradientStop Color="#A8A8A8" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="#C0C0C0"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#C0C0C0" Opacity="0.5" BlurRadius="25" ShadowDepth="4"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleX)"
                                               To="1.05" Duration="0:0:0.25"/>
                                <DoubleAnimation Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleY)"
                                               To="1.05" Duration="0:0:0.25"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleX)"
                                               To="1" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleY)"
                                               To="1" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Gold VIP Card Style -->
        <Style x:Key="VipCardGoldStyle" TargetType="Border" BasedOn="{StaticResource VipCardBaseStyle}">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FFD700" Offset="0"/>
                        <GradientStop Color="#FFA500" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="#FFD700"/>
            <Setter Property="BorderThickness" Value="3"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#FFD700" Opacity="0.6" BlurRadius="30" ShadowDepth="6"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleX)"
                                               To="1.08" Duration="0:0:0.25"/>
                                <DoubleAnimation Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleY)"
                                               To="1.08" Duration="0:0:0.25"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleX)"
                                               To="1" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleY)"
                                               To="1" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Diamond VIP Card Style -->
        <Style x:Key="VipCardDiamondStyle" TargetType="Border" BasedOn="{StaticResource VipCardBaseStyle}">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#00E5FF" Offset="0"/>
                        <GradientStop Color="#9B59FF" Offset="0.5"/>
                        <GradientStop Color="#00E5FF" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="#00E5FF"/>
            <Setter Property="BorderThickness" Value="3"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#00E5FF" Opacity="0.7" BlurRadius="35" ShadowDepth="8"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleX)"
                                               To="1.1" Duration="0:0:0.3"/>
                                <DoubleAnimation Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleY)"
                                               To="1.1" Duration="0:0:0.3"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleX)"
                                               To="1" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleY)"
                                               To="1" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Modern Button Style -->
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#9B59FF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#8E44AD"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#7D3C98"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Badge Base Style -->
        <Style x:Key="BadgeBaseStyle" TargetType="Border">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Turkish Status Badges -->
        <Style x:Key="TurkishSupportedBadge" TargetType="Border" BasedOn="{StaticResource BadgeBaseStyle}">
            <Setter Property="Background" Value="#27AE60"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#27AE60" Opacity="0.3" BlurRadius="8" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TurkishPatchBadge" TargetType="Border" BasedOn="{StaticResource BadgeBaseStyle}">
            <Setter Property="Background" Value="#E67E22"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#E67E22" Opacity="0.3" BlurRadius="8" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="EnglishBadge" TargetType="Border" BasedOn="{StaticResource BadgeBaseStyle}">
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#3498DB" Opacity="0.3" BlurRadius="8" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TranslationInProgressBadge" TargetType="Border" BasedOn="{StaticResource BadgeBaseStyle}">
            <Setter Property="Background" Value="#F39C12"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#F39C12" Opacity="0.3" BlurRadius="8" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Steam Status Badges -->
        <Style x:Key="SteamAvailableBadge" TargetType="Border" BasedOn="{StaticResource BadgeBaseStyle}">
            <Setter Property="Background" Value="#1E90FF"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#1E90FF" Opacity="0.3" BlurRadius="8" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SteamComingSoonBadge" TargetType="Border" BasedOn="{StaticResource BadgeBaseStyle}">
            <Setter Property="Background" Value="#FFD700"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#FFD700" Opacity="0.3" BlurRadius="8" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SteamNotAvailableBadge" TargetType="Border" BasedOn="{StaticResource BadgeBaseStyle}">
            <Setter Property="Background" Value="#7F8C8D"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#7F8C8D" Opacity="0.3" BlurRadius="8" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- VIP Badge -->
        <Style x:Key="VipBadge" TargetType="Border" BasedOn="{StaticResource BadgeBaseStyle}">
            <Setter Property="Background" Value="#FFD700"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#FFD700" Opacity="0.4" BlurRadius="10" ShadowDepth="3"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Update Status Badges -->
        <Style x:Key="UpdatedBadge" TargetType="Border" BasedOn="{StaticResource BadgeBaseStyle}">
            <Setter Property="Background" Value="#27AE60"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#27AE60" Opacity="0.3" BlurRadius="8" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="UpdateAvailableBadge" TargetType="Border" BasedOn="{StaticResource BadgeBaseStyle}">
            <Setter Property="Background" Value="#E74C3C"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#E74C3C" Opacity="0.3" BlurRadius="8" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="OutdatedBadge" TargetType="Border" BasedOn="{StaticResource BadgeBaseStyle}">
            <Setter Property="Background" Value="#95A5A6"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#95A5A6" Opacity="0.3" BlurRadius="8" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Badge Text Style -->
        <Style x:Key="BadgeTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- Game Card Style -->
        <Style x:Key="GameCardStyle" TargetType="Border">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#1E1E28" Offset="0"/>
                        <GradientStop Color="#16161E" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Width" Value="240"/>
            <Setter Property="Height" Value="320"/>
            <Setter Property="Margin" Value="0,0,20,20"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" Opacity="0.5" BlurRadius="25" ShadowDepth="8"/>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="#2D2D3A"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleX)"
                                               To="1.06" Duration="0:0:0.3"/>
                                <DoubleAnimation Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleY)"
                                               To="1.06" Duration="0:0:0.3"/>
                                <ColorAnimation Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                               To="#9B59FF" Duration="0:0:0.3"/>
                                <DoubleAnimation Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.BlurRadius)"
                                               To="35" Duration="0:0:0.3"/>
                                <DoubleAnimation Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.Opacity)"
                                               To="0.7" Duration="0:0:0.3"/>
                                <DoubleAnimation Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.ShadowDepth)"
                                               To="12" Duration="0:0:0.3"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleX)"
                                               To="1" Duration="0:0:0.25"/>
                                <DoubleAnimation Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleY)"
                                               To="1" Duration="0:0:0.25"/>
                                <ColorAnimation Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                               To="#2D2D3A" Duration="0:0:0.25"/>
                                <DoubleAnimation Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.BlurRadius)"
                                               To="25" Duration="0:0:0.25"/>
                                <DoubleAnimation Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.Opacity)"
                                               To="0.5" Duration="0:0:0.25"/>
                                <DoubleAnimation Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.ShadowDepth)"
                                               To="8" Duration="0:0:0.25"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" BorderThickness="0,0,1,0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#121216" Offset="0"/>
                    <GradientStop Color="#1A1A22" Offset="0.5"/>
                    <GradientStop Color="#121216" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#2A2A30" Offset="0"/>
                    <GradientStop Color="#9B59FF44" Offset="0.5"/>
                    <GradientStop Color="#2A2A30" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>
            <Border.Effect>
                <DropShadowEffect Color="#9B59FF" Opacity="0.15" BlurRadius="20" ShadowDepth="0"/>
            </Border.Effect>
            <StackPanel Margin="20,24">
                <!-- Logo -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,32">
                    <Border Width="48" Height="48" CornerRadius="12" Background="#9B59FF22">
                        <TextBlock Text="🎮" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center" Margin="16,0,0,0">
                        <TextBlock Text="RenPyTR" Foreground="White" FontSize="22" FontWeight="Bold"/>
                        <TextBlock Text="Launcher" Foreground="#9B59FF" FontSize="13" FontWeight="SemiBold"/>
                    </StackPanel>
                </StackPanel>

                <!-- Menu Items -->
                <Button x:Name="BtnAnaSayfa" Margin="0,4" Style="{StaticResource SidebarButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🏠" FontSize="18" Foreground="#3498DB"/>
                        <TextBlock Text=" Ana Sayfa" Margin="8,0,0,0"/>
                    </StackPanel>
                </Button>
                <Button x:Name="BtnOyunlar" Margin="0,4" Style="{StaticResource SidebarButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🎮" FontSize="18" Foreground="#9B59FF"/>
                        <TextBlock Text=" Oyunlar" Margin="8,0,0,0"/>
                    </StackPanel>
                </Button>
                <Button x:Name="BtnTurkceYamalar" Margin="0,4" Style="{StaticResource SidebarButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🇹🇷" FontSize="18" Foreground="#E74C3C"/>
                        <TextBlock Text=" Türkçe Yamalar" Margin="8,0,0,0"/>
                    </StackPanel>
                </Button>
                <Button x:Name="BtnFavoriler" Margin="0,4" Style="{StaticResource SidebarButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="❤️" FontSize="18" Foreground="#E74C3C"/>
                        <TextBlock Text=" Favoriler" Margin="8,0,0,0"/>
                    </StackPanel>
                </Button>
                <Button x:Name="BtnKategori" Margin="0,4" Style="{StaticResource SidebarButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📂" FontSize="18" Foreground="#95A5A6"/>
                        <TextBlock Text=" Kategoriler" Margin="8,0,0,0"/>
                    </StackPanel>
                </Button>
                <Button x:Name="BtnVip" Margin="0,4" Style="{StaticResource SidebarButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="💎" FontSize="18" Foreground="#FFD700"/>
                        <TextBlock Text=" VIP" Margin="8,0,0,0"/>
                    </StackPanel>
                </Button>
                <Button x:Name="BtnProfil" Margin="0,4" Style="{StaticResource SidebarButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="👤" FontSize="18" Foreground="#1ABC9C"/>
                        <TextBlock Text=" Profil" Margin="8,0,0,0"/>
                    </StackPanel>
                </Button>
                <Button x:Name="BtnAyarlar" Margin="0,4" Style="{StaticResource SidebarButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚙️" FontSize="18" Foreground="#F39C12"/>
                        <TextBlock Text=" Ayarlar" Margin="8,0,0,0"/>
                    </StackPanel>
                </Button>
                <Button x:Name="BtnAdmin" Margin="0,4" Style="{StaticResource SidebarButtonStyle}" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🛠" FontSize="18" Foreground="#FFD700"/>
                        <TextBlock Text=" Admin Paneli" Margin="8,0,0,0"/>
                    </StackPanel>
                </Button>

                <!-- Spacer -->
                <Border Height="1" Background="#2A2A35" Margin="0,24,0,24"/>

                <!-- User Info -->
                <Border Background="#1A1A22" CornerRadius="12" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="👤" FontSize="16" Foreground="#1ABC9C"/>
                            <TextBlock Text="{Binding CurrentUser.Username, FallbackValue='Kullanıcı'}" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="8,0,0,0" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🏷" FontSize="16" Foreground="#9B59FF"/>
                            <TextBlock Text="{Binding CurrentUser.Role, FallbackValue='Üye'}" Foreground="#888" FontSize="13" Margin="8,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Logout Button -->
                <Button x:Name="BtnLogout" Style="{StaticResource SidebarLogoutButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🚪" FontSize="18"/>
                        <TextBlock Text=" Çıkış Yap" Margin="8,0,0,0"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- Content -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top bar: notifications only -->
            <Border Grid.Row="0" Background="#121216" BorderBrush="#2A2A30" BorderThickness="0,0,0,1" Padding="24,16">
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button x:Name="BtnNotifications" Content="🔔" Width="48" Height="48"
                            Background="#1A1A22" Foreground="White" BorderThickness="0" FontSize="18"
                            Cursor="Hand" Click="BtnNotifications_Click"/>
                    <Border x:Name="NotificationBadge" Background="#E74C3C" CornerRadius="10"
                            Width="20" Height="20" Margin="-16,-8,0,0" VerticalAlignment="Top"
                            Visibility="{Binding HasUnreadNotifications, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding UnreadNotificationCount}" Foreground="White"
                                   FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Notification dropdown -->
            <Border x:Name="NotificationPanel" Grid.Row="0" Visibility="Collapsed"
                    Background="#1A1A22" BorderBrush="#2A2A30" BorderThickness="1"
                    CornerRadius="12" Width="380" MaxHeight="420"
                    HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,64,24,0"
                    Panel.ZIndex="100">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Background="#222228" Padding="16,12" CornerRadius="12,12,0,0">
                        <Grid>
                            <TextBlock Text="🔔 Bildirimler" Foreground="White" FontWeight="SemiBold" FontSize="14"/>
                            <Button Content="Tümünü okundu işaretle"
                                    HorizontalAlignment="Right"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    FontSize="12"
                                    Cursor="Hand"
                                    Click="MarkAllNotifications_Click"/>
                        </Grid>
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="360">
                        <ItemsControl ItemsSource="{Binding Notifications}" Margin="12">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#222228" CornerRadius="8" Padding="14" Margin="0,0,0,8"
                                            Cursor="Hand" MouseLeftButtonUp="NotificationItem_Click">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding TypeIcon}" FontSize="20" Margin="0,0,12,0"/>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Title}" Foreground="White" FontWeight="SemiBold" FontSize="13"/>
                                                <TextBlock Text="{Binding Message}" Foreground="#888" FontSize="12" TextTrimming="CharacterEllipsis" Margin="0,4,0,0"/>
                                                <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}" Foreground="#555" FontSize="11" Margin="0,4,0,0"/>
                                            </StackPanel>
                                            <Ellipse Grid.Column="1" Width="8" Height="8" Fill="#9B59FF"
                                                     HorizontalAlignment="Right" VerticalAlignment="Top"
                                                     Visibility="{Binding IsRead, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="#0D0D0F">
            <StackPanel Margin="32,24">

                <!-- ANA SAYFA -->
                <StackPanel x:Name="PageAnaSayfa">
                    <!-- Search and Filter Bar -->
                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#1A1A22" CornerRadius="12" Padding="16,12">
                            <Grid>
                                <TextBlock Text="🔍 Oyun ara..." Foreground="#666" FontSize="14" VerticalAlignment="Center" IsHitTestVisible="False" Margin="0,0,0,0"/>
                                <TextBox x:Name="TxtSearch" Background="Transparent" BorderThickness="0" Foreground="White" FontSize="14" Padding="0" VerticalAlignment="Center" CaretBrush="#9B59FF"/>
                            </Grid>
                        </Border>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0,0,0">
                            <Button Content="🎮 Tümü" Background="#1A1A22" Foreground="White" BorderThickness="0" Padding="16,10" Margin="0,0,8,0" Cursor="Hand" FontSize="13"/>
                            <Button Content="🇹🇷 Yamalar" Background="Transparent" Foreground="#888" BorderThickness="1" BorderBrush="#333" Padding="16,10" Margin="0,0,8,0" Cursor="Hand" FontSize="13"/>
                            <Button Content="❤️ Favoriler" Background="Transparent" Foreground="#888" BorderThickness="1" BorderBrush="#333" Padding="16,10" Cursor="Hand" FontSize="13"/>
                        </StackPanel>
                    </Grid>

                    <!-- Featured Hero Banner -->
                    <Border CornerRadius="16" Height="320" Margin="0,0,0,32">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#1A0A2E" Offset="0"/>
                                <GradientStop Color="#2D1B4E" Offset="0.5"/>
                                <GradientStop Color="#9B59FF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <Grid Margin="32">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.2*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <Border Background="#9B59FF33" CornerRadius="6" Padding="12,6" HorizontalAlignment="Left" Margin="0,0,0,16">
                                        <TextBlock Text="⭐ ÖNE ÇIKAN" Foreground="#9B59FF" FontSize="12" FontWeight="Bold"/>
                                    </Border>
                                    <TextBlock Text="Summer Memories" Foreground="White" FontSize="42" FontWeight="Bold" Margin="0,0,0,12" TextWrapping="Wrap"/>
                                    <TextBlock Text="En popüler Türkçe yama oyunu. Hikaye modu, gelişmiş grafikler ve daha fazlası." Foreground="#E0E0E8" FontSize="16" TextWrapping="Wrap" Margin="0,0,0,24" MaxWidth="500"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="🎮 Şimdi Oyna" Background="#9B59FF" Foreground="White" BorderThickness="0" Padding="24,12" Cursor="Hand" FontSize="15" FontWeight="SemiBold" Margin="0,0,12,0"/>
                                        <Button Content="ℹ️ Detaylar" Background="Transparent" Foreground="White" BorderThickness="2" BorderBrush="#FFFFFF44" Padding="24,12" Cursor="Hand" FontSize="15"/>
                                    </StackPanel>
                                </StackPanel>
                                <Border Grid.Column="1" Width="380" Height="260" CornerRadius="16" Background="#00000033" VerticalAlignment="Center" Margin="24,0,0,0">
                                    <Grid>
                                        <Border Background="#2A2A35" CornerRadius="16"/>
                                        <TextBlock Text="🎮" FontSize="80" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.3"/>
                                        <Border VerticalAlignment="Bottom" Height="80" CornerRadius="0,0,16,16">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                                                    <GradientStop Color="#00000088" Offset="0"/>
                                                    <GradientStop Color="Transparent" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Announcement Banner -->
                    <Border Background="#1A1A22" CornerRadius="12" Padding="24" Margin="0,0,0,32" Visibility="{Binding HasAnnouncement, Converter={StaticResource BoolToVis}}">
                        <Grid>
                            <Border Background="{Binding CurrentAnnouncement.AccentColor, Converter={StaticResource StringToBrush}, TargetNullValue='#9B59FF'}" Opacity="0.15" CornerRadius="12"/>
                            <StackPanel Margin="12">
                                <TextBlock Text="📢 DUYURU" Foreground="#9B59FF" FontSize="12" FontWeight="Bold"/>
                                <TextBlock Text="{Binding CurrentAnnouncement.Title, FallbackValue='Hoş Geldiniz'}"
                                           Foreground="White" FontSize="20" FontWeight="Bold" Margin="0,6,0,0"/>
                                <TextBlock Text="{Binding CurrentAnnouncement.Message, FallbackValue='RenPyTR Launcher'}"
                                           Foreground="#B0B0B8" FontSize="14" TextWrapping="Wrap" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Yeni Eklenenler -->
                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" FontSize="24" FontWeight="Bold" Foreground="White" Text="✨ Yeni Eklenenler"/>
                        <Button Grid.Column="1" Content="Tümünü Gör →" Foreground="#9B59FF" Background="Transparent" BorderThickness="0" FontSize="13" Cursor="Hand"/>
                    </Grid>
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="0,0,0,40">
                        <ItemsControl ItemsSource="{Binding Recent}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource GameCardStyle}" MouseLeftButtonUp="GameCard_Click" Tag="{Binding}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="220"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <ContentControl Grid.Row="0" Content="{Binding}">
                                                <ContentControl.ContentTemplate>
                                                    <DataTemplate>
                                                        <Grid>
                                                            <Border Background="#252530" CornerRadius="18,18,0,0"/>
                                                            <TextBlock Text="🎮" FontSize="64" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.15"/>
                                                            <Image Source="{Binding ImagePath, Converter={StaticResource SafeImage}, FallbackValue={x:Null}}" Stretch="UniformToFill"/>
                                                            <!-- Gradient Overlay -->
                                                            <Border VerticalAlignment="Bottom" Height="100" CornerRadius="0,0,18,0">
                                                                <Border.Background>
                                                                    <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                                                                        <GradientStop Color="#16161E" Offset="0"/>
                                                                        <GradientStop Color="Transparent" Offset="1"/>
                                                                    </LinearGradientBrush>
                                                                </Border.Background>
                                                            </Border>
                                                            <!-- Badges Container -->
                                                            <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Margin="12">
                                                                <!-- VIP Badge -->
                                                                <Border Background="#FFD700" CornerRadius="10" Padding="8,5" Margin="0,0,0,6"
                                                                        Visibility="{Binding IsVip, Converter={StaticResource BoolToVis}}"
                                                                        Effect="{StaticResource CardShadow}">
                                                                    <TextBlock Text="💎 VIP" Foreground="#1A1A22" FontSize="10" FontWeight="Bold"/>
                                                                </Border>
                                                                <!-- Steam Badge -->
                                                                <Border Background="#1E90FF" CornerRadius="10" Padding="8,5" Margin="0,0,0,6"
                                                                        Effect="{StaticResource CardShadow}">
                                                                    <TextBlock Text="🟦 Steam" Foreground="White" FontSize="10" FontWeight="SemiBold"/>
                                                                </Border>
                                                                <!-- Turkish Status Badge -->
                                                                <Border Background="#27AE60" CornerRadius="10" Padding="8,5"
                                                                        Effect="{StaticResource CardShadow}">
                                                                    <TextBlock Text="🇹🇷 Türkçe" Foreground="White" FontSize="10" FontWeight="SemiBold"/>
                                                                </Border>
                                                            </StackPanel>
                                                            <!-- Favorite Heart -->
                                                            <Border Background="#00000088" CornerRadius="28" Padding="14" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="12" Cursor="Hand">
                                                                <TextBlock Text="🤍" FontSize="22"/>
                                                            </Border>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ContentControl.ContentTemplate>
                                            </ContentControl>
                                            <StackPanel Grid.Row="1" Margin="18,16">
                                                <TextBlock Text="{Binding Name}" Foreground="White" FontWeight="Bold" FontSize="17" TextTrimming="CharacterEllipsis" Margin="0,0,0,8" LineHeight="1.3"/>
                                                <TextBlock Foreground="#A0A0B0" FontSize="13" Margin="0,0,0,12" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" MaxHeight="40">
                                                    <Run Text="{Binding Description}" Foreground="#808090"/>
                                                </TextBlock>
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Background="#2D2D3A" CornerRadius="8" Padding="10,6" Margin="0,0,8,0">
                                                        <TextBlock Text="📅" Foreground="#9B59FF" FontSize="12"/>
                                                    </Border>
                                                    <TextBlock Foreground="#808090" FontSize="12" VerticalAlignment="Center">
                                                        <Run Text="{Binding AddedDate, StringFormat='{}{0:dd.MM.yyyy}', FallbackValue='-'}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Güncellenenler -->
                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" FontSize="24" FontWeight="Bold" Foreground="White" Text="🔄 Güncellenenler"/>
                        <Button Grid.Column="1" Content="Tümünü Gör →" Foreground="#9B59FF" Background="Transparent" BorderThickness="0" FontSize="13" Cursor="Hand"/>
                    </Grid>
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="0,0,0,40">
                        <ItemsControl ItemsSource="{Binding UpdatedGames}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource GameCardStyle}" MouseLeftButtonUp="GameCard_Click" Tag="{Binding}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="220"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <ContentControl Grid.Row="0" Content="{Binding}">
                                                <ContentControl.ContentTemplate>
                                                    <DataTemplate>
                                                        <Grid>
                                                            <Border Background="#252530" CornerRadius="18,18,0,0"/>
                                                            <TextBlock Text="🎮" FontSize="64" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.15"/>
                                                            <Image Source="{Binding ImagePath, Converter={StaticResource SafeImage}, FallbackValue={x:Null}}" Stretch="UniformToFill"/>
                                                            <!-- Gradient Overlay -->
                                                            <Border VerticalAlignment="Bottom" Height="100" CornerRadius="0,0,18,0">
                                                                <Border.Background>
                                                                    <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                                                                        <GradientStop Color="#16161E" Offset="0"/>
                                                                        <GradientStop Color="Transparent" Offset="1"/>
                                                                    </LinearGradientBrush>
                                                                </Border.Background>
                                                            </Border>
                                                            <!-- Badges Container -->
                                                            <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Margin="12">
                                                                <!-- VIP Badge -->
                                                                <Border Background="#FFD700" CornerRadius="10" Padding="8,5" Margin="0,0,0,6"
                                                                        Visibility="{Binding IsVip, Converter={StaticResource BoolToVis}}"
                                                                        Effect="{StaticResource CardShadow}">
                                                                    <TextBlock Text="💎 VIP" Foreground="#1A1A22" FontSize="10" FontWeight="Bold"/>
                                                                </Border>
                                                                <!-- Steam Badge -->
                                                                <Border Background="#1E90FF" CornerRadius="10" Padding="8,5" Margin="0,0,0,6"
                                                                        Effect="{StaticResource CardShadow}">
                                                                    <TextBlock Text="🟦 Steam" Foreground="White" FontSize="10" FontWeight="SemiBold"/>
                                                                </Border>
                                                                <!-- Turkish Status Badge -->
                                                                <Border Background="#27AE60" CornerRadius="10" Padding="8,5"
                                                                        Effect="{StaticResource CardShadow}">
                                                                    <TextBlock Text="🇹🇷 Türkçe" Foreground="White" FontSize="10" FontWeight="SemiBold"/>
                                                                </Border>
                                                            </StackPanel>
                                                            <!-- Favorite Heart -->
                                                            <Border Background="#00000088" CornerRadius="28" Padding="14" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="12" Cursor="Hand">
                                                                <TextBlock Text="🤍" FontSize="22"/>
                                                            </Border>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ContentControl.ContentTemplate>
                                            </ContentControl>
                                            <StackPanel Grid.Row="1" Margin="18,16">
                                                <TextBlock Text="{Binding Name}" Foreground="White" FontWeight="Bold" FontSize="17" TextTrimming="CharacterEllipsis" Margin="0,0,0,8" LineHeight="1.3"/>
                                                <TextBlock Foreground="#A0A0B0" FontSize="13" Margin="0,0,0,12" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" MaxHeight="40">
                                                    <Run Text="{Binding Description}" Foreground="#808090"/>
                                                </TextBlock>
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Background="#2D2D3A" CornerRadius="8" Padding="10,6" Margin="0,0,8,0">
                                                        <TextBlock Text="📅" Foreground="#9B59FF" FontSize="12"/>
                                                    </Border>
                                                    <TextBlock Foreground="#808090" FontSize="12" VerticalAlignment="Center">
                                                        <Run Text="{Binding UpdatedDate, StringFormat='{}{0:dd.MM.yyyy}', FallbackValue='-'}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                                <WrapPanel Orientation="Horizontal">
                                                    <!-- Turkish Status Badge -->
                                                    <Border>
                                                        <Border.Style>
                                                            <Style TargetType="Border" BasedOn="{StaticResource BadgeBaseStyle}">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding TurkishStatus}" Value="TurkishSupported">
                                                                        <Setter Property="Background" Value="#27AE60"/>
                                                                        <Setter Property="Effect">
                                                                            <Setter.Value>
                                                                                <DropShadowEffect Color="#27AE60" Opacity="0.3" BlurRadius="8" ShadowDepth="2"/>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding TurkishStatus}" Value="TurkishPatchAvailable">
                                                                        <Setter Property="Background" Value="#E67E22"/>
                                                                        <Setter Property="Effect">
                                                                            <Setter.Value>
                                                                                <DropShadowEffect Color="#E67E22" Opacity="0.3" BlurRadius="8" ShadowDepth="2"/>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding TurkishStatus}" Value="English">
                                                                        <Setter Property="Background" Value="#3498DB"/>
                                                                        <Setter Property="Effect">
                                                                            <Setter.Value>
                                                                                <DropShadowEffect Color="#3498DB" Opacity="0.3" BlurRadius="8" ShadowDepth="2"/>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding TurkishStatus}" Value="TranslationInProgress">
                                                                        <Setter Property="Background" Value="#F39C12"/>
                                                                        <Setter Property="Effect">
                                                                            <Setter.Value>
                                                                                <DropShadowEffect Color="#F39C12" Opacity="0.3" BlurRadius="8" ShadowDepth="2"/>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock>
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock" BasedOn="{StaticResource BadgeTextStyle}">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding TurkishStatus}" Value="TurkishSupported">
                                                                            <Setter Property="Text" Value="🇹🇷 Türkçe Destekli"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding TurkishStatus}" Value="TurkishPatchAvailable">
                                                                            <Setter Property="Text" Value="🔧 Türkçe Yama Var"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding TurkishStatus}" Value="English">
                                                                            <Setter Property="Text" Value="🌍 İngilizce"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding TurkishStatus}" Value="TranslationInProgress">
                                                                            <Setter Property="Text" Value="🚧 Çeviri Devam Ediyor"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Border>
                                                    <!-- Steam Status Badge -->
                                                    <Border>
                                                        <Border.Style>
                                                            <Style TargetType="Border" BasedOn="{StaticResource BadgeBaseStyle}">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding SteamStatus}" Value="Available">
                                                                        <Setter Property="Background" Value="#1E90FF"/>
                                                                        <Setter Property="Effect">
                                                                            <Setter.Value>
                                                                                <DropShadowEffect Color="#1E90FF" Opacity="0.3" BlurRadius="8" ShadowDepth="2"/>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding SteamStatus}" Value="ComingSoon">
                                                                        <Setter Property="Background" Value="#FFD700"/>
                                                                        <Setter Property="Effect">
                                                                            <Setter.Value>
                                                                                <DropShadowEffect Color="#FFD700" Opacity="0.3" BlurRadius="8" ShadowDepth="2"/>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding SteamStatus}" Value="NotAvailable">
                                                                        <Setter Property="Background" Value="#7F8C8D"/>
                                                                        <Setter Property="Effect">
                                                                            <Setter.Value>
                                                                                <DropShadowEffect Color="#7F8C8D" Opacity="0.3" BlurRadius="8" ShadowDepth="2"/>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </DataTrigger>
