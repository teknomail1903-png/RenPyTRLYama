                                                    </ItemsControl>
                                                    <Button Content="Satın Al" Tag="{Binding PurchaseUrl}" Click="PurchaseMembership_Click"
                                                            Background="White" Foreground="Black" BorderThickness="0" FontWeight="Bold" Cursor="Hand" Margin="0,24,0,0" Height="48" FontSize="15"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </WrapPanel>
                    </StackPanel>
                </Grid>

                <!-- PROFİL -->
                <Grid x:Name="PageProfil" Visibility="Collapsed">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="24">
                            <!-- Top Profile Card -->
                            <Border CornerRadius="20" Margin="0,0,0,32" Effect="{StaticResource CardShadow}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#1A1A2E" Offset="0"/>
                                        <GradientStop Color="#16213E" Offset="0.5"/>
                                        <GradientStop Color="#0F3460" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Grid Margin="32">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid Width="120" Height="120">
                                        <Ellipse Fill="#2D2D3A" Stroke="#9B59FF" StrokeThickness="4"/>
                                        <Image Source="{Binding CurrentUser.AvatarPath, Converter={StaticResource SafeImage}}" Stretch="UniformToFill">
                                            <Image.Clip>
                                                <EllipseGeometry Center="60,60" RadiusX="56" RadiusY="56"/>
                                            </Image.Clip>
                                        </Image>
                                        <Ellipse Stroke="White" StrokeThickness="2" StrokeDashArray="4,2" Opacity="0.3"/>
                                    </Grid>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="24,0,0,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding CurrentUser.Username, FallbackValue='Anonim'}" Foreground="White" FontSize="32" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                                            <Border x:Name="VipBadgeBorder" CornerRadius="12" Padding="12,6" Margin="16,0,0,0" Visibility="{Binding IsVipUser, Converter={StaticResource BoolToVis}}">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CurrentUser.MembershipLevel}" Value="Bronze">
                                                                <Setter Property="Background" Value="#CD7F32"/>
                                                                <Setter Property="Effect">
                                                                    <Setter.Value>
                                                                        <DropShadowEffect Color="#CD7F32" Opacity="0.4" BlurRadius="12" ShadowDepth="2"/>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding CurrentUser.MembershipLevel}" Value="Silver">
                                                                <Setter Property="Background" Value="#C0C0C0"/>
                                                                <Setter Property="Effect">
                                                                    <Setter.Value>
                                                                        <DropShadowEffect Color="#C0C0C0" Opacity="0.4" BlurRadius="12" ShadowDepth="2"/>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding CurrentUser.MembershipLevel}" Value="Gold">
                                                                <Setter Property="Background" Value="#FFD700"/>
                                                                <Setter Property="Effect">
                                                                    <Setter.Value>
                                                                        <DropShadowEffect Color="#FFD700" Opacity="0.4" BlurRadius="12" ShadowDepth="2"/>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding CurrentUser.MembershipLevel}" Value="Diamond">
                                                                <Setter Property="Background">
                                                                    <Setter.Value>
                                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                            <GradientStop Color="#B9F2FF" Offset="0"/>
                                                                            <GradientStop Color="#00D4FF" Offset="1"/>
                                                                        </LinearGradientBrush>
                                                                    </Setter.Value>
                                                                </Setter>
                                                                <Setter Property="Effect">
                                                                    <Setter.Value>
                                                                        <DropShadowEffect Color="#00D4FF" Opacity="0.4" BlurRadius="12" ShadowDepth="2"/>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock x:Name="VipBadgeText" Text="💎 VIP" Foreground="Black" FontSize="14" FontWeight="Bold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding CurrentUser.MembershipLevel}" Value="Bronze">
                                                                    <Setter Property="Text" Value="🥉 BRONZE"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding CurrentUser.MembershipLevel}" Value="Silver">
                                                                    <Setter Property="Text" Value="🥈 SILVER"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding CurrentUser.MembershipLevel}" Value="Gold">
                                                                    <Setter Property="Text" Value="🥇 GOLD"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding CurrentUser.MembershipLevel}" Value="Diamond">
                                                                    <Setter Property="Text" Value="💎 DIAMOND"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding CurrentUser.Email, FallbackValue='email@example.com'}" Foreground="#AAA" FontSize="14" Margin="0,8,0,0"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                            <Border Background="#1A1A22" CornerRadius="8" Padding="10,6" Margin="0,0,8,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="📅" FontSize="14" Margin="0,0,6,0"/>
                                                    <TextBlock Text="{Binding CurrentUser.CreatedDate, StringFormat='{}{0:dd.MM.yyyy}', FallbackValue='-'}" Foreground="#CCC" FontSize="13"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Background="#1A1A22" CornerRadius="8" Padding="10,6">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="👑" FontSize="14" Margin="0,0,6,0"/>
                                                    <TextBlock Text="{Binding RoleDisplay}" Foreground="#CCC" FontSize="13"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <Button x:Name="BtnEditProfile" Content="✏️" Width="44" Height="44" Margin="0,0,0,8" Background="#1A1A22" Foreground="White" BorderThickness="0" Cursor="Hand" FontSize="18" ToolTip="Profili Düzenle"/>
                                        <Button x:Name="BtnChangeAvatar" Content="📷" Width="44" Height="44" Margin="0,0,0,8" Background="#1A1A22" Foreground="White" BorderThickness="0" Cursor="Hand" FontSize="18" ToolTip="Avatar Değiştir"/>
                                        <Button x:Name="BtnChangePassword" Content="🔐" Width="44" Height="44" Background="#1A1A22" Foreground="White" BorderThickness="0" Cursor="Hand" FontSize="18" ToolTip="Şifre Değiştir"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Statistics Cards -->
                            <TextBlock Text="📊 İstatistikler" FontSize="24" Foreground="White" FontWeight="Bold" Margin="0,0,0,20"/>
                            <UniformGrid Columns="4" Margin="0,0,0,32">
                                <Border Background="#1A1A22" CornerRadius="16" Margin="0,0,12,0" Padding="24" Effect="{StaticResource CardShadow}">
                                    <StackPanel>
                                        <TextBlock Text="🎮" FontSize="28" Margin="0,0,0,8"/>
                                        <TextBlock Text="Toplam Oyun" Foreground="#888" FontSize="13"/>
                                        <TextBlock Text="{Binding TotalGamesCount, FallbackValue=0}" Foreground="White" FontSize="28" FontWeight="Bold" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#1A1A22" CornerRadius="16" Margin="6,0" Padding="24" Effect="{StaticResource CardShadow}">
                                    <StackPanel>
                                        <TextBlock Text="⬇️" FontSize="28" Margin="0,0,0,8"/>
                                        <TextBlock Text="Toplam İndirme" Foreground="#888" FontSize="13"/>
                                        <TextBlock Text="{Binding CurrentUserTotalDownloads}" Foreground="White" FontSize="28" FontWeight="Bold" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#1A1A22" CornerRadius="16" Margin="6,0" Padding="24" Effect="{StaticResource CardShadow}">
                                    <StackPanel>
                                        <TextBlock Text="❤️" FontSize="28" Margin="0,0,0,8"/>
                                        <TextBlock Text="Favoriler" Foreground="#888" FontSize="13"/>
                                        <TextBlock Text="{Binding FavoriteGames.Count}" Foreground="White" FontSize="28" FontWeight="Bold" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#1A1A22" CornerRadius="16" Margin="12,0,0,0" Padding="24" Effect="{StaticResource CardShadow}">
                                    <StackPanel>
                                        <TextBlock Text="🏆" FontSize="28" Margin="0,0,0,8"/>
                                        <TextBlock Text="Kazanılan Rozetler" Foreground="#888" FontSize="13"/>
                                        <TextBlock Text="{Binding CurrentUser.Badges.Count, FallbackValue=0}" Foreground="White" FontSize="28" FontWeight="Bold" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <!-- Account Information -->
                            <TextBlock Text="👤 Hesap Bilgileri" FontSize="24" Foreground="White" FontWeight="Bold" Margin="0,0,0,20"/>
                            <Border Background="#1A1A22" CornerRadius="16" Padding="28" Margin="0,0,0,32" Effect="{StaticResource CardShadow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Kullanıcı Adı" Foreground="#888" FontSize="13" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding CurrentUser.Username, FallbackValue='-'}" Foreground="White" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>
                                        <TextBlock Text="E-Posta" Foreground="#888" FontSize="13" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding CurrentUser.Email, FallbackValue='-'}" Foreground="White" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>
                                        <TextBlock Text="Üyelik Türü" Foreground="#888" FontSize="13" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding CurrentUser.MembershipLevel, FallbackValue='Ücretsiz'}" Foreground="White" FontSize="16" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="24,0,0,0">
                                        <TextBlock Text="Son Giriş Tarihi" Foreground="#888" FontSize="13" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding CurrentUser.LastLoginDate, StringFormat='{}{0:dd.MM.yyyy HH:mm}', FallbackValue='-'}" Foreground="White" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>
                                        <TextBlock Text="Kayıt Tarihi" Foreground="#888" FontSize="13" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding CurrentUser.CreatedDate, StringFormat='{}{0:dd.MM.yyyy}', FallbackValue='-'}" Foreground="White" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>
                                        <TextBlock Text="Hesap Durumu" Foreground="#888" FontSize="13" Margin="0,0,0,4"/>
                                        <TextBlock Text="Aktif" Foreground="#27AE60" FontSize="16" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Quick Actions -->
                            <TextBlock Text="⚡ Hızlı İşlemler" FontSize="24" Foreground="White" FontWeight="Bold" Margin="0,0,0,20"/>
                            <WrapPanel Margin="0,0,0,32">
                                <Button x:Name="BtnProfileAccountSettings" Content="⚙️ Hesap Ayarları" Width="180" Height="48" Margin="0,0,12,12" Background="#1A1A22" Foreground="White" BorderThickness="0" Cursor="Hand" FontSize="14" FontWeight="SemiBold" Style="{StaticResource ModernButtonStyle}"/>
                                <Button x:Name="BtnProfileMyFavorites" Content="❤️ Favorilerim" Width="180" Height="48" Margin="0,0,12,12" Background="#1A1A22" Foreground="White" BorderThickness="0" Cursor="Hand" FontSize="14" FontWeight="SemiBold" Style="{StaticResource ModernButtonStyle}"/>
                                <Button x:Name="BtnProfileNotifications" Content="🔔 Bildirimler" Width="180" Height="48" Margin="0,0,12,12" Background="#1A1A22" Foreground="White" BorderThickness="0" Cursor="Hand" FontSize="14" FontWeight="SemiBold" Style="{StaticResource ModernButtonStyle}"/>
                                <Button x:Name="BtnProfileLogout" Content="🚪 Çıkış Yap" Width="180" Height="48" Margin="0,0,0,12" Background="#E74C3C" Foreground="White" BorderThickness="0" Cursor="Hand" FontSize="14" FontWeight="SemiBold" Style="{StaticResource ModernButtonStyle}"/>
                            </WrapPanel>

                            <!-- Account Security -->
                            <TextBlock Text="🔒 Hesap Güvenliği" FontSize="24" Foreground="White" FontWeight="Bold" Margin="0,0,0,20"/>
                            <Border Background="#1A1A22" CornerRadius="16" Padding="28" Margin="0,0,0,32" Effect="{StaticResource CardShadow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <Border Background="#27AE6022" CornerRadius="12" Padding="16" Margin="0,0,0,0">
                                            <StackPanel>
                                                <TextBlock Text="🔐" FontSize="24" Margin="0,0,0,8"/>
                                                <TextBlock Text="Şifre Durumu" Foreground="#888" FontSize="13"/>
                                                <TextBlock Text="Güçlü" Foreground="#27AE60" FontSize="16" FontWeight="SemiBold" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                        <Border Background="#95A5A622" CornerRadius="12" Padding="16">
                                            <StackPanel>
                                                <TextBlock Text="🔑" FontSize="24" Margin="0,0,0,8"/>
                                                <TextBlock Text="2FA Durumu" Foreground="#888" FontSize="13"/>
                                                <TextBlock Text="Pasif" Foreground="#95A5A6" FontSize="16" FontWeight="SemiBold" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Margin="12,0,0,0">
                                        <Border Background="#3498DB22" CornerRadius="12" Padding="16">
                                            <StackPanel>
                                                <TextBlock Text="📍" FontSize="24" Margin="0,0,0,8"/>
                                                <TextBlock Text="Son Giriş" Foreground="#888" FontSize="13"/>
                                                <TextBlock Text="{Binding CurrentUser.LastLoginDate, StringFormat='{}{0:dd.MM}', FallbackValue='-'}" Foreground="#3498DB" FontSize="16" FontWeight="SemiBold" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Favorites Section -->
                            <TextBlock Text="❤️ Favorilerim" FontSize="24" Foreground="White" FontWeight="Bold" Margin="0,0,0,20"/>
                            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="0,0,0,24">
                                <ItemsControl ItemsSource="{Binding FavoriteGames}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource GameCardStyle}" MouseLeftButtonUp="FavoriteGame_Click" Tag="{Binding}" Margin="0,0,16,16">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="160"/>
                                                        <RowDefinition Height="*"/>
                                                    </Grid.RowDefinitions>
                                                    <ContentControl Grid.Row="0" Content="{Binding}">
                                                        <ContentControl.ContentTemplate>
                                                            <DataTemplate>
                                                                <Grid>
                                                                    <Border Background="#2A2A35"/>
                                                                    <TextBlock Text="🎮" FontSize="40" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.4"/>
                                                                    <Image Source="{Binding ImagePath, Converter={StaticResource SafeImage}, FallbackValue={x:Null}}" Stretch="UniformToFill"/>
                                                                    <Border Background="#00000066" CornerRadius="20" Padding="8" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="8" Cursor="Hand">
                                                                        <TextBlock Text="❤️" FontSize="16"/>
                                                                    </Border>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ContentControl.ContentTemplate>
                                                    </ContentControl>
                                                    <StackPanel Grid.Row="1" Margin="12,10">
                                                        <TextBlock Text="{Binding Name}" Foreground="White" FontWeight="SemiBold" FontSize="14" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Foreground="#888" FontSize="12" Margin="0,6,0,0">
                                                            <Run Text="📅 "/><Run Text="{Binding AddedDate, StringFormat='{}{0:dd.MM.yyyy}', FallbackValue='-'}"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- FAVORİLER -->
                <Grid x:Name="PageFavoriler" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock FontSize="22" FontWeight="Bold" Foreground="White" Margin="0,0,0,16">
                            <Run Text="❤️ Favorilerim ("/><Run Text="{Binding FavoriteCount, Mode=OneWay}"/><Run Text=")"/>
                        </TextBlock>
                        <TextBlock Text="Favori oyunlarınızı buradan yönetebilirsiniz." Foreground="#888" FontSize="14" Margin="0,0,0,24"/>
                        <WrapPanel>
                            <ItemsControl ItemsSource="{Binding FavoriteGames}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource GameCardStyle}" MouseLeftButtonUp="GameCard_Click" Tag="{Binding}">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="160"/>
                                                    <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>
                                                <ContentControl Grid.Row="0" Content="{Binding}">
                                                    <ContentControl.ContentTemplate>
                                                        <DataTemplate>
                                                            <Grid>
                                                                <Border Background="#2A2A35"/>
                                                                <TextBlock Text="🎮" FontSize="40" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.4"/>
                                                                <Image Source="{Binding ImagePath, Converter={StaticResource SafeImage}, FallbackValue={x:Null}}" Stretch="UniformToFill"/>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ContentControl.ContentTemplate>
                                                </ContentControl>
                                                <StackPanel Grid.Row="1" Margin="12,10">
                                                    <TextBlock Text="{Binding Name}" Foreground="White" FontWeight="SemiBold" FontSize="14" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Foreground="#888" FontSize="12" Margin="0,6,0,0">
                                                        <Run Text="📅 "/><Run Text="{Binding AddedDate, StringFormat='{}{0:dd.MM.yyyy}', FallbackValue='-'}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </WrapPanel>
                    </StackPanel>
                </Grid>

                <!-- AYARLAR -->
                <Grid x:Name="PageAyarlar" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="⚙️ Ayarlar" FontSize="22" FontWeight="Bold" Foreground="White" Margin="0,0,0,16"/>
                        
                        <TextBlock Text="Bağlantılar" Foreground="#888" FontSize="14" Margin="0,0,0,12"/>
                        <WrapPanel Margin="0,0,0,32">
                            <Button Content="🌐 Web Sitesi" Tag="{Binding WebsiteUrl}" Click="OpenLink_Click" Background="#9B59FF" Foreground="White" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand" Width="200" Height="48" Margin="0,0,12,12" FontSize="14"/>
                            <Button Content="💬 Discord" Tag="{Binding DiscordUrl}" Click="OpenLink_Click" Background="#9B59FF" Foreground="White" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand" Width="200" Height="48" Margin="0,0,12,12" FontSize="14"/>
                            <Button Content="📢 Duyurular" Tag="{Binding AnnouncementsUrl}" Click="OpenLink_Click" Background="#9B59FF" Foreground="White" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand" Width="200" Height="48" Margin="0,0,12,12" FontSize="14"/>
                            <Button Content="🆘 Destek" Tag="{Binding SupportUrl}" Click="OpenLink_Click" Background="#9B59FF" Foreground="White" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand" Width="200" Height="48" Margin="0,0,12,12" FontSize="14"/>
                        </WrapPanel>

                        <TextBlock Text="Bakım" Foreground="#888" FontSize="14" Margin="0,0,0,12"/>
                        <Border Background="#1A1A22" CornerRadius="12" Padding="24" Margin="0,0,0,32">
                            <WrapPanel>
                                <Button x:Name="BtnCheckUpdates" Content="🔄 Güncellemeleri Kontrol Et" Height="44" Width="240" Margin="0,0,12,12" Background="#222228" Foreground="White" BorderThickness="0" Cursor="Hand" FontSize="14"/>
                                <Button x:Name="BtnClearSaves" Content="🧹 Kayıt Dosyalarını Temizle" Height="44" Width="240" Margin="0,0,12,12" Background="#222228" Foreground="White" BorderThickness="0" Cursor="Hand" FontSize="14"/>
                                <Button x:Name="BtnClearCache" Content="🧽 Cache Temizle" Height="44" Width="240" Margin="0,0,12,12" Background="#222228" Foreground="White" BorderThickness="0" Cursor="Hand" FontSize="14"/>
                                <Button x:Name="BtnClearLogs" Content="📄 Log Dosyalarını Temizle" Height="44" Width="240" Margin="0,0,12,12" Background="#222228" Foreground="White" BorderThickness="0" Cursor="Hand" FontSize="14"/>
                                <Button x:Name="BtnOpenGamesFolder" Content="📂 Oyun Klasörünü Aç" Height="44" Width="240" Margin="0,0,12,12" Background="#222228" Foreground="White" BorderThickness="0" Cursor="Hand" FontSize="14"/>
                                <Button x:Name="BtnOpenBackupFolder" Content="📁 Yedek Klasörünü Aç" Height="44" Width="240" Margin="0,0,12,12" Background="#222228" Foreground="White" BorderThickness="0" Cursor="Hand" FontSize="14"/>
                                <Button x:Name="BtnRollbackLast" Content="↩ Son Yedeği Geri Al" Height="44" Width="240" Margin="0,0,12,12" Background="#222228" Foreground="White" BorderThickness="0" Cursor="Hand" FontSize="14"/>
                            </WrapPanel>
                        </Border>

                        <TextBlock Text="🎨 Tema" Foreground="#888" FontSize="14" Margin="0,0,0,12"/>
                        <Border Background="#1A1A22" CornerRadius="12" Padding="24">
                            <StackPanel>
                                <TextBlock Text="Launcher temasını seçin" Foreground="White" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,16"/>
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton x:Name="RbThemeSteam" Content="Steam Dark Theme" Foreground="White"
                                                 GroupName="Theme" Margin="0,0,32,0" FontSize="14" Checked="ThemeChanged"/>
                                    <RadioButton x:Name="RbThemeDiscord" Content="Discord Dark Theme" Foreground="White"
                                                 GroupName="Theme" FontSize="14" Checked="ThemeChanged"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <TextBlock Text="Launcher Sürümü: v1.1" Foreground="#666" FontSize="12" Margin="0,24,0,0"/>
                    </StackPanel>
                </Grid>

            </StackPanel>
        </ScrollViewer>
        </Grid>
    </Grid>
</Window>
